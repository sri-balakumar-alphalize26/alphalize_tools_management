<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_partial_return_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <style>
                          /* Force fonts + layout locally so the invoice always renders correctly,
                             even if Odoo report assets (Lato font + Bootstrap grid) fail to load. */
                          .page, .page * { font-family: 'Lato','Helvetica Neue','Segoe UI',Helvetica,Arial,sans-serif !important; }
                          .page { font-size: 10px; color: #333; }
                          .page .row { display: block !important; width: 100%; }
                          .page .row:after { content: ""; display: table; clear: both; }
                          .page .col-6 { float: left; width: 50%; box-sizing: border-box; }
                          .page .col-5 { width: 41.6%; box-sizing: border-box; }
                          .page .text-end { text-align: right !important; }
                          .page .text-center { text-align: center !important; }
                          .page table.table { width: 100%; border-collapse: collapse; }
                          .page table.table td { padding: 2px 5px; vertical-align: top; }
                          .page .inv-table { table-layout: fixed; }
                          .inv-table th { background-color:#e9ecef; color:#333; padding:3px 5px; font-size:9px; border:1px solid #dee2e6; font-weight:600; }
                          .inv-table td { padding:2px 5px; border:1px solid #dee2e6; font-size:10px; vertical-align:middle; }
                          .inv-table { border-collapse:collapse; width:100%; margin-bottom:6px; }
                          .totals-table { width:50%; margin-left:auto; border-collapse:collapse; }
                          .totals-table td { padding:2px 6px; font-size:10px; }
                          .grand-row { border-top:2px solid #000; }
                          .grand-row td { font-size:12px; font-weight:700; }
                          .inv-footer { margin-top:4px; font-size:7px; color:#aaa; text-align:center; border-top:1px solid #eee; padding-top:2px; }
                          .terms-section { page-break-inside: auto; page-break-before: auto; }
                          .sig-section { page-break-inside: avoid; page-break-before: avoid; }
                        </style>

                        <!-- Invoice Header -->
                        <t t-set="cfg" t-value="doc.env['rental.invoice.settings'].sudo().get_for_company(doc.company_id)"/>
                        <table style="width:100%; border:1px solid #fff; border-spacing:0; margin-bottom:4px;">
                            <tr>
                                <td style="width:30%; text-align:left; vertical-align:middle; padding:4px 8px 4px 10px; border:1px solid #fff;">
                                    <div style="font-size:18px; font-weight:900; color:#00AEEF; letter-spacing:1px;"><t t-esc="cfg.company_name"/></div>
                                    <div style="font-size:12px; font-weight:700; color:#333; letter-spacing:0.5px;"><t t-esc="cfg.company_subname"/></div>
                                    <div style="font-size:7px; color:#333; margin-top:1px;"><t t-esc="cfg.cr_address"/></div>
                                    <div style="font-size:7px; color:#333;"><t t-esc="cfg.phone_numbers"/></div>
                                    <div style="font-size:7px; color:#333;"><t t-esc="cfg.branch_email"/></div>
                                    <div style="font-size:7px; color:#333;"><t t-esc="cfg.vat_number"/></div>
                                </td>
                                <td style="width:40%; text-align:center; vertical-align:middle; padding-bottom:8px; border:1px solid #fff;">
                                    <div style="margin-bottom:6px;">
                                <img t-if="cfg.center_logo" t-att-src="image_data_uri(cfg.center_logo)"
                                     style="max-width:160px; max-height:80px; object-fit:contain;"/>
                                    </div>
                                    <h2 style="color:#2c3e50; margin:0 0 2px 0; font-size:16px;"><t t-esc="cfg.heading_partial_return"/></h2>
                                    <div style="color:#888; font-size:12px; margin-bottom:4px;">
                                        <span t-field="doc.name"/>
                                    </div>
                                    <t t-if="doc.customer_code">
                                        <span style="background:#714B67; color:#fff; padding:4px 14px; border-radius:4px; font-size:12px; font-weight:700; letter-spacing:1px;">
                                            Customer ID: <t t-out="doc.customer_code"/>
                                        </span>
                                    </t>
                                </td>
                                <td style="width:30%; text-align:right; vertical-align:middle; direction:rtl; padding:4px 10px 4px 8px; border:1px solid #fff;">
                                    <div style="font-size:18px; font-weight:900; color:#00AEEF;"><t t-esc="cfg.company_name_ar"/></div>
                                    <div style="font-size:12px; font-weight:700; color:#333;"><t t-esc="cfg.company_subname_ar"/></div>
                                    <div style="font-size:7px; color:#333; margin-top:1px;"><t t-esc="cfg.cr_address_ar"/></div>
                                    <div style="font-size:9px; color:#333;"><t t-esc="cfg.phone_numbers_ar"/></div>
                                    <div style="font-size:9px; color:#333;"><t t-esc="cfg.branch_email_ar"/></div>
                                </td>
                            </tr>
                        </table>
                        <div style="border-bottom:2px solid #2c3e50; margin-bottom:4px;"></div>
                        <!-- Parties -->
                        <div class="row" style="margin-bottom:4px;">
                            <div class="col-6">
                                <strong>Rental Company:</strong><br/>
                                <span t-field="doc.company_id.partner_id.name"/><br/>
                                <t t-if="doc.company_id.partner_id.street">
                                    <span t-field="doc.company_id.partner_id.street"/><br/>
                                </t>
                                <t t-if="doc.company_id.partner_id.city">
                                    <span t-field="doc.company_id.partner_id.city"/>
                                </t>
                                <t t-if="doc.company_id.partner_id.zip">
                                    <span t-field="doc.company_id.partner_id.zip"/>
                                </t>
                                <br/>
                                <t t-if="doc.company_id.phone">
                                    Ph: <span t-field="doc.company_id.phone"/>
                                </t>
                            </div>
                            <div class="col-6" style="text-align:right;">
                                <strong>Customer:</strong><br/>
                                <span t-field="doc.partner_id.name"/><br/>
                                <t t-if="doc.partner_id.street">
                                    <span t-field="doc.partner_id.street"/><br/>
                                </t>
                                <t t-if="doc.partner_id.city">
                                    <span t-field="doc.partner_id.city"/>
                                </t>
                                <t t-if="doc.partner_id.zip">
                                    <span t-field="doc.partner_id.zip"/>
                                </t>
                                <br/>
                                <t t-if="doc.partner_phone">
                                    Ph: <span t-field="doc.partner_phone"/>
                                </t>
                                <t t-if="doc.partner_email">
                                    <br/><span t-field="doc.partner_email"/>
                                </t>
                            </div>
                        </div>

                        <!-- Rental Details -->
                        <table class="table table-sm" style="margin-bottom:4px;">
                            <tr>
                                <td><strong>Order Date:</strong></td>
                                <td><span t-field="doc.date_order" t-options='{"widget": "date"}'/></td>
                                <td><strong>Check-Out Date:</strong></td>
                                <td><span t-field="doc.date_checkout" t-options='{"widget": "datetime"}'/></td>
                            </tr>
                            <tr t-if="doc.partial_return_date">
                                <td/>
                                <td/>
                                <td><strong>Partial Return Date:</strong></td>
                                <td><span t-field="doc.partial_return_date" t-options='{"widget": "datetime"}'/></td>
                            </tr>
                            <tr>
                                <td><strong>Responsible:</strong></td>
                                <td><span t-field="doc.user_id.name"/></td>
                                <td><strong>Advance Collected:</strong></td>
                                <td><span t-field="doc.advance_amount"/></td>
                            </tr>
                            <tr t-if="doc.payment_method">
                                <td><strong>Payment Method:</strong></td>
                                <td><span t-field="doc.payment_method"/></td>
                                <td/>
                                <td/>
                            </tr>
                            <tr t-if="doc.payment_method == 'cash' and doc.cash_received">
                                <td><strong>Cash Received:</strong></td>
                                <td><span t-field="doc.cash_received"/></td>
                                <td><strong>Balance Returned:</strong></td>
                                <td><span t-field="doc.cash_balance"/></td>
                            </tr>
                        </table>

                        <!-- Tools Table -->
                        <h5 style="margin-top:4px; margin-bottom:3px; font-size:11px; color:#333;">Tools / Equipment</h5>
                        <table class="inv-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Tool</th>
                                    <th>Serial No.</th>
                                    <th>Return Date</th>
                                    <th>Condition</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end">Duration</th>
                                    <th class="text-end">Extra Days</th>
                                    <th class="text-end">Late Fee</th>
                                    <th class="text-end">Total</th>
                                    <th t-if="doc.tax_total" class="text-end">Tax %</th>
                                    <th t-if="doc.tax_total" class="text-end">Tax Amt</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="idx" t-value="0"/>
                                <tr t-foreach="doc.line_ids.filtered(lambda l: l.is_partial_return)" t-as="line">
                                    <t t-set="idx" t-value="idx + 1"/>
                                    <td><t t-out="idx"/></td>
                                    <td>
                                        <t t-if="line.product_id">
                                            <span t-field="line.product_id.name"/>
                                        </t>
                                        <t t-elif="line.tool_id">
                                            <span t-field="line.tool_id.name"/>
                                        </t>
                                    </td>
                                    <td><span t-esc="line.tool_id.serial_number or ''"/></td>
                                    <td>
                                        <t t-if="line.partial_return_date">
                                            <span t-field="line.partial_return_date" t-options='{"widget": "date"}'/>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-if="line.checkout_condition">
                                            <span t-field="line.checkout_condition"/>
                                        </t>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.unit_price"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="int(line.planned_duration)"/>
                                        <t t-if="line.period_type == 'week'">
                                            <t t-if="int(line.planned_duration) == 1"> Week</t>
                                            <t t-else=""> Weeks</t>
                                        </t>
                                        <t t-elif="line.period_type == 'month'">
                                            <t t-if="int(line.planned_duration) == 1"> Month</t>
                                            <t t-else=""> Months</t>
                                        </t>
                                        <t t-else="">
                                            <t t-if="int(line.planned_duration) == 1"> Day</t>
                                            <t t-else=""> Days</t>
                                        </t>
                                    </td>
                                    <td class="text-end"
                                        t-att-style="'color:red; font-weight:bold;' if line.extra_days else ''">
                                        <span t-esc="line.extra_days"/>
                                    </td>
                                    <td class="text-end"
                                        t-att-style="'color:red; font-weight:bold;' if line.late_fee_amount else ''">
                                        <span t-field="line.late_fee_amount"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.rental_cost"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <td t-if="doc.tax_total" class="text-end">
                                        <t t-if="line.tax_percentage">
                                            <span t-esc="str(line.tax_percentage) + '%'"/>
                                        </t>
                                    </td>
                                    <td t-if="doc.tax_total" class="text-end">
                                        <span t-field="line.tax_amount"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Totals -->
                        <div class="row">
                            <div class="col-6"/>
                            <div class="col-6" style="float:right;">
                                <table class="totals-table">
                                    <tr>
                                        <td><strong>Subtotal:</strong></td>
                                        <td class="text-end"><span t-field="doc.subtotal"/></td>
                                    </tr>
                                    <t t-if="doc.late_fee">
                                        <tr style="color:red; font-weight:bold;">
                                            <td>Late Fees:</td>
                                            <td class="text-end"><span t-field="doc.late_fee"/></td>
                                        </tr>
                                    </t>
                                    <tr t-if="doc.tax_total">
                                        <td>Tax:</td>
                                        <td class="text-end"><span t-field="doc.tax_total"/></td>
                                    </tr>
                                    <tr t-if="doc.advance_amount">
                                        <td>Advance Collected:</td>
                                        <td class="text-end"><span t-field="doc.advance_amount"/></td>
                                    </tr>
                                    <tr t-if="doc.payment_method">
                                        <td>Payment Method:</td>
                                        <td class="text-end"><span t-field="doc.payment_method"/></td>
                                    </tr>
                                    <tr t-if="doc.payment_method == 'cash' and doc.cash_received">
                                        <td>Cash Received:</td>
                                        <td class="text-end"><span t-field="doc.cash_received"/></td>
                                    </tr>
                                    <tr t-if="doc.payment_method == 'cash' and doc.cash_balance">
                                        <td>Balance Returned:</td>
                                        <td class="text-end"><span t-field="doc.cash_balance"/></td>
                                    </tr>
                                    <tr class="grand-row">
                                        <td><strong>TOTAL:</strong></td>
                                        <td class="text-end">
                                            <strong><span t-field="doc.total_amount"/></strong>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Bilingual Terms & Conditions -->
                        <div t-if="cfg.show_terms" style="margin-top:8px; border-top:1px solid #ccc; padding-top:6px;">
                            <h5 style="font-size:10px; margin:0 0 4px;">Terms &amp; Conditions / الشروط والأحكام</h5>
                            <table style="width:100%; border-collapse:collapse; font-size:8px; color:#444;">
                                <tr t-foreach="cfg.terms_line_ids" t-as="term" style="border-bottom:1px solid #f0f0f0;">
                                    <td style="padding:1px 4px; vertical-align:top; font-weight:600; width:3%;"><t t-esc="term_index + 1"/>.</td>
                                    <td style="padding:1px 4px; width:50%; line-height:1.3;"><t t-esc="term.text_en"/></td>
                                    <td style="padding:1px 4px; text-align:right; direction:rtl; width:47%; line-height:1.4;"><t t-esc="term.text_ar"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- Signature -->
                        <div class="row" style="margin-top:8px; justify-content:center;">
                            <div class="col-5 text-center" style="margin:0 auto;">
                                <t t-if="doc.checkin_customer_signature">
                                    <img t-att-src="image_data_uri(doc.checkin_customer_signature)"
                                         style="max-height:50px; max-width:100%;"/>
                                    <br/>
                                </t>
                                <t t-else="">
                                    <hr/>
                                </t>
                                <strong>Customer Signature</strong><br/>
                                <span t-field="doc.partner_id.name"/>
                                <t t-if="doc.checkout_signature_date">
                                    <br/>
                                    <small style="color:#666; font-size:9px;">
                                        Signed on:
                                        <span t-field="doc.checkout_signature_date"
                                              t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm"}'/>
                                    </small>
                                </t>
                            </div>
                        </div>

                        <!-- Corner Image -->
                        <div style="text-align:right; margin-top:10px;">
                            <img t-if="cfg.right_logo" t-att-src="image_data_uri(cfg.right_logo)"
                                 style="width:250px; height:auto;"/>
                        </div>

                        <!-- Footer -->
                        <div class="inv-footer">
                            Generated on <span t-esc="datetime.datetime.now().strftime('%d/%m/%Y %H:%M')"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_partial_return_invoice_a5">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <style>
                          @page { size: 148mm 210mm; margin: 3mm 3mm 5mm 3mm; }
                          body { padding:4px; font-size:7px; }
                          /* Force fonts + layout locally so the invoice always renders correctly,
                             even if Odoo report assets (Lato font + Bootstrap grid) fail to load. */
                          .page, .page * { font-family: 'Lato','Helvetica Neue','Segoe UI',Helvetica,Arial,sans-serif !important; }
