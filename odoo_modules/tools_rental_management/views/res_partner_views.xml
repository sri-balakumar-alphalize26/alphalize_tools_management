<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit the partner tree view to add js_class for Delete button -->
    <record id="view_partner_tree_inherit_delete" model="ir.ui.view">
        <field name="name">res.partner.tree.inherit.delete</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="js_class">contact_list_delete</attribute>
            </xpath>
        </field>
    </record>

    <!-- Inherit the partner form view to add ID Proof fields -->
    <record id="view_partner_form_inherit_id_proof" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.id.proof</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <separator string="ID Proof Documents"/>
                <group col="2">
                    <group string="ID Proof - Front">
                        <field name="id_proof_front" widget="image"
                               nolabel="1"
                               options='{"size": [300, 200], "zoom": true}'/>
                    </group>
                    <group string="ID Proof - Back">
                        <field name="id_proof_back" widget="image"
                               nolabel="1"
                               options='{"size": [300, 200], "zoom": true}'/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Customer ID Proofs — List View -->
    <record id="view_customer_id_proof_tree" model="ir.ui.view">
        <field name="name">res.partner.id.proof.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="Customer ID Proofs" create="false">
                <field name="name" string="Customer"/>
                <field name="phone" string="Phone"/>
                <field name="email" optional="show"/>
                <field name="id_proof_front" widget="image"
                       options='{"size": [60, 40]}' string="ID Front"/>
                <field name="id_proof_back" widget="image"
                       options='{"size": [60, 40]}' string="ID Back"/>
            </list>
        </field>
    </record>

    <!-- Customer ID Proofs — Action -->
    <record id="action_customer_id_proofs" model="ir.actions.act_window">
        <field name="name">Customer ID Proofs</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_customer_id_proof_tree')})]"/>
        <field name="domain">[('id_proof_front', '!=', False)]</field>
        <field name="context">{'default_customer_rank': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No customer ID proofs found
            </p>
            <p>Customer ID proofs are automatically saved when tools are checked out.</p>
        </field>
    </record>

    <!-- Customer Ratings — List View -->
    <record id="view_customer_ratings_tree" model="ir.ui.view">
        <field name="name">res.partner.customer.ratings.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="Customer Ratings" create="false">
                <field name="name" string="Customer"/>
                <field name="phone" optional="show"/>
                <field name="email" optional="hide"/>
                <field name="customer_rating" widget="badge"
                       decoration-success="customer_rating == 'perfect'"
                       decoration-info="customer_rating == 'very_good'"
                       decoration-primary="customer_rating == 'good'"
                       decoration-warning="customer_rating == 'fair'"
                       decoration-danger="customer_rating == 'poor'"
                       decoration-muted="customer_rating == 'skipped'"
                       string="Rating"/>
                <field name="customer_rating_date" string="Last Rated"/>
                <field name="customer_rating_notes" string="Notes" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Customer Ratings — Action -->
    <record id="action_customer_ratings" model="ir.actions.act_window">
        <field name="name">Customer Ratings</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_customer_ratings_tree')})]"/>
        <field name="domain">[('customer_rating', '!=', False)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No customer ratings yet
            </p>
            <p>Customer ratings are saved automatically after each check-in.</p>
        </field>
    </record>

</odoo>
