<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ TOOL CATEGORY ═══ -->
    <record id="view_rental_tool_category_tree" model="ir.ui.view">
        <field name="name">rental.tool.category.tree</field>
        <field name="model">rental.tool.category</field>
        <field name="arch" type="xml">
            <list decoration-muted="active == False">
                <field name="active" column_invisible="1"/>
                <field name="code" string="Code"/>
                <field name="name" string="Category Name"/>
                <field name="parent_id" string="Parent"/>
                <field name="tool_count" string="Tools" decoration-info="tool_count > 0"/>
                <field name="child_count" string="Sub Categories" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_rental_tool_category_kanban" model="ir.ui.view">
        <field name="name">rental.tool.category.kanban</field>
        <field name="model">rental.tool.category</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
                <field name="tool_count"/>
                <field name="child_count"/>
                <field name="active"/>
                <templates>
                    <t t-name="card"
                       t-attf-class="o_rental_category_card {{ record.tool_count.raw_value > 0 ? 'o_rental_category_has_tools' : '' }}">
                        <div class="o_rental_category_card_header">
                            <strong class="o_rental_category_card_title">
                                <field name="name"/>
                            </strong>
                            <span t-if="record.code.value"
                                  class="o_rental_category_card_badge">
                                <field name="code"/>
                            </span>
                        </div>
                        <div t-if="record.parent_id.value"
                             class="o_rental_category_card_parent">
                            <i class="fa fa-folder-open-o me-1"/>
                            <field name="parent_id"/>
                        </div>
                        <div class="o_rental_category_card_stats">
                            <span class="o_rental_category_card_stat">
                                <i class="fa fa-wrench me-1"/>
                                <field name="tool_count"/> Tools
                            </span>
                            <span t-if="record.child_count.raw_value > 0"
                                  class="o_rental_category_card_stat">
                                <i class="fa fa-sitemap me-1"/>
                                <field name="child_count"/> Sub
                            </span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_rental_tool_category_form" model="ir.ui.view">
        <field name="name">rental.tool.category.form</field>
        <field name="model">rental.tool.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tools" type="object"
                                class="oe_stat_button" icon="fa-wrench">
                            <field name="tool_count" widget="statinfo"
                                   string="Tools"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Category Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="code" placeholder="e.g. PWR, HND, MSR"/>
                            <field name="parent_id"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Hierarchy">
                            <field name="child_count" string="Sub Categories"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sub Categories" name="children"
                              invisible="child_count == 0">
                            <field name="child_ids" mode="list">
                                <list>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="tool_count"/>
                                </list>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="description"
                                   placeholder="Describe this tool category..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Delete old act_window, create client action ── -->
    <delete model="ir.actions.act_window"
            search="[('xml_id', '=', 'tools_rental_management.action_rental_tool_category')]"/>

    <record id="action_rental_category_dashboard" model="ir.actions.client">
        <field name="name">Tool Categories</field>
        <field name="tag">rental_category_dashboard</field>
    </record>

    <!-- ═══ TOOL / EQUIPMENT ═══ -->
    <record id="view_rental_tool_tree" model="ir.ui.view">
        <field name="name">rental.tool.tree</field>
        <field name="model">rental.tool</field>
        <field name="arch" type="xml">
            <list create="false"
                  decoration-success="state == 'available'"
                  decoration-warning="state == 'maintenance'"
                  decoration-danger="state == 'rented'"
                  decoration-muted="state == 'retired'">
                <field name="code" string="Serial No." optional="show"/>
                <field name="name" string="Product"/>
                <field name="rental_price_per_day" string="Price/Day" widget="monetary"/>
                <field name="late_fee_per_day" string="Late Fee/Day" widget="monetary"/>
                <field name="available_qty" string="On Hand"/>
                <field name="state" string="Status" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-warning="state == 'maintenance'"
                       decoration-danger="state == 'rented'"
                       decoration-muted="state == 'retired'"/>
                <field name="category_id" string="Category" optional="show"/>
                <field name="total_rental_count" string="Rentals" optional="show"/>
                <field name="total_revenue" string="Revenue" optional="hide"/>
                <field name="location" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_rental_tool_kanban" model="ir.ui.view">
        <field name="name">rental.tool.kanban</field>
        <field name="model">rental.tool</field>
        <field name="arch" type="xml">
            <kanban create="false">
                <field name="name"/>
                <field name="code"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="state"/>
                <field name="total_qty"/>
                <field name="available_qty"/>
                <field name="rental_price_per_day"/>
                <field name="late_fee_per_day"/>
                <field name="image"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card" class="o_rental_tool_card">
                        <!-- Image section with status badge overlay -->
                        <div class="o_rental_card_image">
                            <field name="image" widget="image"
                                   options='{"preview_image": "image"}'/>
                            <div class="o_rental_card_badge">
                                <t t-if="record.state.raw_value == 'rented'">
                                    <span class="badge text-bg-danger">Checked Out</span>
                                </t>
                                <t t-elif="record.state.raw_value == 'maintenance'">
                                    <span class="badge text-bg-warning">Maintenance</span>
                                </t>
                                <t t-elif="record.state.raw_value == 'retired'">
                                    <span class="badge text-bg-secondary">Retired</span>
                                </t>
                                <t t-else="">
                                    <span class="badge text-bg-success">Available</span>
                                </t>
                            </div>
                        </div>
                        <!-- Details section -->
                        <div class="o_rental_card_body">
                            <strong class="o_rental_card_title">
                                <field name="name"/>
                            </strong>
                            <div t-if="record.serial_number.value"
                                 class="o_rental_card_serial">
                                <i class="fa fa-barcode me-1"/>
                                <field name="serial_number"/>
                            </div>
                            <div t-elif="record.code.value"
                                 class="o_rental_card_serial">
                                <i class="fa fa-barcode me-1"/>
                                <field name="code"/>
                            </div>
                            <div class="o_rental_card_prices">
                                <div class="o_rental_card_price">
                                    <field name="rental_price_per_day" widget="monetary"/>
                                    <span class="o_rental_card_price_label">/day</span>
                                </div>
                                <div t-if="record.late_fee_per_day.raw_value > 0"
                                     class="o_rental_card_late">
                                    Late: <field name="late_fee_per_day" widget="monetary"/>/day
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_rental_tool_form" model="ir.ui.view">
        <field name="name">rental.tool.form</field>
        <field name="model">rental.tool</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_available" type="object"
                            string="Set Available"
                            invisible="state == 'available'"
                            class="btn-primary"/>
                    <button name="action_set_maintenance" type="object"
                            string="Under Maintenance"
                            invisible="state in ('maintenance', 'retired')"/>
                    <button name="action_set_retired" type="object"
                            string="Retire" confirm="Are you sure you want to retire this tool?"
                            invisible="state == 'retired'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="available,rented,maintenance"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(tools_rental_management.action_rental_order)d"
                                type="action" class="oe_stat_button" icon="fa-handshake-o">
                            <field name="total_rental_count" widget="statinfo"
                                   string="Rentals"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"
                           options='{"preview_image": "image"}'/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Tool Name"/></h1>
                    </div>
                    <group>
                        <group string="Information">
                            <field name="code"/>
                            <field name="category_id"/>
                            <field name="brand"/>
                            <field name="model_name"/>
                            <field name="serial_number"/>
                            <field name="barcode"/>
                            <field name="total_qty"/>
                            <field name="available_qty"/>
                            <field name="rental_price_per_day" widget="monetary"/>
                            <field name="late_fee_per_day" widget="monetary"/>
                        </group>
                        <group string="Location &amp; Finance">
                            <field name="location"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="purchase_date"/>
                            <field name="purchase_price"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="product_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Tool description and specifications..."/>
                        </page>
                        <page string="Pricing" name="pricing">
                            <field name="pricing_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="price" string="Price / Day"/>
                                    <field name="late_fee_per_day" string="Late Fee / Day"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="period_type" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_rental_tool_search" model="ir.ui.view">
        <field name="name">rental.tool.search</field>
        <field name="model">rental.tool</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="barcode"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="brand"/>
                <separator/>
                <filter name="available" string="Available"
                        domain="[('state', '=', 'available')]"/>
                <filter name="rented" string="Rented"
                        domain="[('state', '=', 'rented')]"/>
                <filter name="maintenance" string="Maintenance"
                        domain="[('state', '=', 'maintenance')]"/>
                <separator/>
                <group>
                    <filter name="group_category" string="Category"
                            context="{'group_by': 'category_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_rental_tool" model="ir.actions.act_window">
        <field name="name">Tools &amp; Equipment</field>
        <field name="res_model">rental.tool</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_rental_tool_search"/>
        <field name="context">{'search_default_available': 1}</field>
    </record>
</odoo>
