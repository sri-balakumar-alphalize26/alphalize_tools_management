<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ LIST VIEW ═══ -->
    <record id="view_rental_tool_report_list" model="ir.ui.view">
        <field name="name">rental.tool.report.list</field>
        <field name="model">rental.tool.report</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false"
                  decoration-success="state == 'available'"
                  decoration-warning="state == 'maintenance'"
                  decoration-danger="state == 'rented'"
                  decoration-muted="state == 'retired'">
                <field name="name"/>
                <field name="serial_number" string="Serial No."/>
                <field name="category_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-warning="state == 'maintenance'"
                       decoration-danger="state == 'rented'"
                       decoration-muted="state == 'retired'"/>
                <field name="total_qty" sum="Total"/>
                <field name="available_qty" sum="Total Available"/>
                <field name="checked_out_qty" sum="Total Checked Out"/>
                <field name="active_rentals" string="Active Orders" sum="Total"/>
                <field name="total_rentals" sum="Total"/>
                <field name="price_per_day" widget="monetary"/>
                <field name="late_fee_per_day" widget="monetary"/>
                <field name="total_revenue" sum="Total Revenue" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ═══ PIVOT VIEW ═══ -->
    <record id="view_rental_tool_report_pivot" model="ir.ui.view">
        <field name="name">rental.tool.report.pivot</field>
        <field name="model">rental.tool.report</field>
        <field name="arch" type="xml">
            <pivot string="Tool Availability Report">
                <field name="category_id" type="row"/>
                <field name="name" type="row"/>
                <field name="total_qty" type="measure"/>
                <field name="available_qty" type="measure"/>
                <field name="checked_out_qty" type="measure"/>
                <field name="total_rentals" type="measure"/>
                <field name="total_revenue" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ═══ GRAPH VIEW ═══ -->
    <record id="view_rental_tool_report_graph" model="ir.ui.view">
        <field name="name">rental.tool.report.graph</field>
        <field name="model">rental.tool.report</field>
        <field name="arch" type="xml">
            <graph string="Tool Availability Report" type="bar">
                <field name="name"/>
                <field name="total_qty" type="measure"/>
                <field name="available_qty" type="measure"/>
                <field name="checked_out_qty" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ═══ SEARCH VIEW ═══ -->
    <record id="view_rental_tool_report_search" model="ir.ui.view">
        <field name="name">rental.tool.report.search</field>
        <field name="model">rental.tool.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="category_id"/>
                <separator/>
                <filter name="available" string="Available"
                        domain="[('state', '=', 'available')]"/>
                <filter name="rented" string="Rented"
                        domain="[('state', '=', 'rented')]"/>
                <filter name="maintenance" string="Maintenance"
                        domain="[('state', '=', 'maintenance')]"/>
                <filter name="has_checked_out" string="Has Checked Out Items"
                        domain="[('checked_out_qty', '>', 0)]"/>
                <separator/>
                <group>
                    <filter name="group_category" string="Category"
                            context="{'group_by': 'category_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ ACTION: Standard list/pivot/graph (kept for reference) ═══ -->
    <record id="action_rental_tool_report" model="ir.actions.act_window">
        <field name="name">Tool Availability (Table)</field>
        <field name="res_model">rental.tool.report</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_rental_tool_report_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No rental tools found
            </p>
        </field>
    </record>

    <!-- ═══ CLIENT ACTION: Dashboard view (primary) ═══ -->
    <record id="action_rental_tool_report_dashboard" model="ir.actions.client">
        <field name="name">Tool Availability Report</field>
        <field name="tag">rental_tool_report_dashboard</field>
    </record>

</odoo>
