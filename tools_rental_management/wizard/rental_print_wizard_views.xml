<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rental_print_wizard_form" model="ir.ui.view">
        <field name="name">rental.print.wizard.form</field>
        <field name="model">rental.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Invoice">
                <group>
                    <field name="order_id" readonly="1"/>
                    <field name="report_type" readonly="1"/>
                    <field name="paper_size" widget="radio"/>
                </group>
                <footer>
                    <button name="action_print" type="object"
                            string="Print" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
