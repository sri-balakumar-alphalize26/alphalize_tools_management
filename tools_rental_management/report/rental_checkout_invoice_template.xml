<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_checkout_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center" style="color: #2c3e50;">CHECKOUT INVOICE</h2>
                        <h4 class="text-center text-muted">
                            <span t-field="doc.name"/>
                        </h4>
                        <br/>

                        <!-- Parties -->
                        <div class="row">
                            <div class="col-6">
                                <strong>Rental Company:</strong><br/>
                                <span t-field="doc.company_id.partner_id.name"/><br/>
                                <t t-if="doc.company_id.partner_id.street">
                                    <span t-field="doc.company_id.partner_id.street"/><br/>
                                </t>
                                <t t-if="doc.company_id.partner_id.city">
                                    <span t-field="doc.company_id.partner_id.city"/>
                                </t>
                                <t t-if="doc.company_id.partner_id.zip">
                                    <span t-field="doc.company_id.partner_id.zip"/>
                                </t>
                                <br/>
                                <t t-if="doc.company_id.phone">
                                    Phone: <span t-field="doc.company_id.phone"/>
                                </t>
                            </div>
                            <div class="col-6">
                                <strong>Customer:</strong><br/>
                                <span t-field="doc.partner_id.name"/><br/>
                                <t t-if="doc.partner_id.street">
                                    <span t-field="doc.partner_id.street"/><br/>
                                </t>
                                <t t-if="doc.partner_id.city">
                                    <span t-field="doc.partner_id.city"/>
                                </t>
                                <t t-if="doc.partner_id.zip">
                                    <span t-field="doc.partner_id.zip"/>
                                </t>
                                <br/>
                                <t t-if="doc.partner_phone">
                                    Phone: <span t-field="doc.partner_phone"/>
                                </t>
                                <t t-if="doc.partner_email">
                                    <br/>Email: <span t-field="doc.partner_email"/>
                                </t>
                            </div>
                        </div>
                        <br/>

                        <!-- Customer ID -->
                        <t t-if="doc.customer_code">
                            <div style="text-align: center; margin-bottom: 12px;">
                                <span style="background-color: #714B67; color: #fff; padding: 6px 18px; border-radius: 4px; font-size: 14px; font-weight: 700; letter-spacing: 1px;">
                                    Customer ID: <t t-out="doc.customer_code"/>
                                </span>
                            </div>
                        </t>

                        <!-- Rental Details -->
                        <table class="table table-sm">
                            <tr>
                                <td><strong>Order Date:</strong></td>
                                <td><span t-field="doc.date_order" t-options='{"widget": "date"}'/></td>
                                <td><strong>Check-Out Date:</strong></td>
                                <td><span t-field="doc.date_checkout" t-options='{"widget": "date"}'/></td>
                            </tr>
                            <tr>
                                <td><strong>Billing Period:</strong></td>
                                <td><span t-field="doc.rental_period_type"/></td>
                                <td><strong>Duration:</strong></td>
                                <td><span t-field="doc.rental_duration"/></td>
                            </tr>
                            <tr>
                                <td><strong>Planned Return:</strong></td>
                                <td><span t-field="doc.date_planned_checkin"/></td>
                                <td><strong>Advance Collected:</strong></td>
                                <td><span t-field="doc.advance_amount"/></td>
                            </tr>
                            <tr>
                                <td><strong>Responsible:</strong></td>
                                <td><span t-field="doc.user_id.name"/></td>
                                <td></td>
                                <td></td>
                            </tr>
                        </table>

                        <!-- Tools Table -->
                        <h5 style="margin-top: 15px;">Tools / Equipment</h5>
                        <table class="table table-bordered table-sm">
                            <thead style="background-color: #e9ecef; color: #333;">
                                <tr>
                                    <th>#</th>
                                    <th>Tool</th>
                                    <th>Serial No.</th>
                                    <th>Condition</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end">Duration</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="idx" t-value="0"/>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <t t-set="idx" t-value="idx + 1"/>
                                    <td><t t-out="idx"/></td>
                                    <td>
                                        <t t-if="line.product_id">
                                            <span t-field="line.product_id.name"/>
                                        </t>
                                        <t t-elif="line.tool_id">
                                            <span t-field="line.tool_id.name"/>
                                        </t>
                                    </td>
                                    <td><span t-esc="line.tool_id.serial_number or ''"/></td>
                                    <td>
                                        <t t-if="line.checkout_condition">
                                            <span t-field="line.checkout_condition"/>
                                        </t>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.unit_price"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="int(line.planned_duration)"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.rental_cost"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Totals -->
                        <div class="row">
                            <div class="col-6"/>
                            <div class="col-6">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Subtotal:</strong></td>
                                        <td class="text-end"><span t-field="doc.subtotal"/></td>
                                    </tr>
                                    <tr t-if="doc.advance_amount">
                                        <td>Advance Collected:</td>
                                        <td class="text-end"><span t-field="doc.advance_amount"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Terms -->
                        <t t-if="doc.terms">
                            <br/>
                            <h5>Terms &amp; Conditions</h5>
                            <div t-field="doc.terms"/>
                        </t>

                        <!-- Signature -->
                        <div class="row" style="margin-top: 40px;">
                            <div class="col-7"/>
                            <div class="col-5 text-center">
                                <t t-if="doc.customer_signature">
                                    <img t-att-src="image_data_uri(doc.customer_signature)"
                                         style="max-height: 80px; max-width: 100%;"/>
                                    <br/>
                                </t>
                                <t t-else="">
                                    <hr/>
                                </t>
                                <strong>Customer Signature</strong><br/>
                                <span t-field="doc.partner_id.name"/>
                                <t t-if="doc.checkout_signature_date">
                                    <br/>
                                    <small style="color: #666;">
                                        Signed on:
                                        <span t-field="doc.checkout_signature_date"
                                              t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm"}'/>
                                    </small>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
