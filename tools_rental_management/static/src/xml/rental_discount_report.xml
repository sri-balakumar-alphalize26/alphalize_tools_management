<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="tools_rental_management.RentalDiscountReport">
<div class="o_action o_rental_discount_report" style="background:#f8f9fa; height:100%; overflow-y:scroll;">

    <!-- ═══ HEADER ═══ -->
    <div style="background:#714B67; color:#fff; padding:16px 24px;
                position:sticky; top:0; z-index:100;
                display:flex; align-items:center; justify-content:space-between;">
        <h3 style="margin:0; font-weight:700;">Discount Details</h3>
        <span class="text-white-50" style="font-size:13px;">
            Showing <t t-esc="filteredOrders.length"/> discounted orders
        </span>
    </div>

    <div style="padding:20px 24px;">

        <!-- ═══ SUMMARY CARDS ═══ -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div style="background:#fff; border-radius:10px; padding:18px;
                            box-shadow:0 1px 4px rgba(0,0,0,0.08); border-left:4px solid #714B67;">
                    <div style="color:#888; font-size:12px; text-transform:uppercase;">Discounted Orders</div>
                    <div style="font-size:28px; font-weight:700; color:#714B67;">
                        <t t-esc="summaryCards.totalDiscounted"/>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:#fff; border-radius:10px; padding:18px;
                            box-shadow:0 1px 4px rgba(0,0,0,0.08); border-left:4px solid #28a745;">
                    <div style="color:#888; font-size:12px; text-transform:uppercase;">Total Discount Given</div>
                    <div style="font-size:28px; font-weight:700; color:#28a745;">
                        <t t-esc="formatMoney(summaryCards.totalDiscount)"/>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:#fff; border-radius:10px; padding:18px;
                            box-shadow:0 1px 4px rgba(0,0,0,0.08); border-left:4px solid #17a2b8;">
                    <div style="color:#888; font-size:12px; text-transform:uppercase;">Avg. Discount/Order</div>
                    <div style="font-size:28px; font-weight:700; color:#17a2b8;">
                        <t t-esc="formatMoney(summaryCards.avgDiscount)"/>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:#fff; border-radius:10px; padding:18px;
                            box-shadow:0 1px 4px rgba(0,0,0,0.08); border-left:4px solid #f0ad4e;">
                    <div style="color:#888; font-size:12px; text-transform:uppercase;">Revenue After Discount</div>
                    <div style="font-size:28px; font-weight:700; color:#f0ad4e;">
                        <t t-esc="formatMoney(summaryCards.totalRevenue)"/>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══ FILTER BAR ═══ -->
        <div style="background:#fff; border-radius:10px; padding:14px 18px;
                    box-shadow:0 1px 4px rgba(0,0,0,0.08); margin-bottom:16px;
                    display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
            <input type="text" class="form-control form-control-sm"
                   style="max-width:300px;"
                   placeholder="Search by Customer ID, Order, Name, Authorized By..."
                   t-on-input="onSearchInput"/>
            <select class="form-select form-select-sm" style="max-width:180px;"
                    t-on-change="onFilterStatus">
                <option value="all">All Statuses</option>
                <option value="checked_out">Checked Out</option>
                <option value="checked_in">Checked In</option>
                <option value="invoiced">Invoiced</option>
            </select>
        </div>

        <!-- ═══ ORDERS TABLE ═══ -->
        <div style="background:#fff; border-radius:10px;
                    box-shadow:0 1px 4px rgba(0,0,0,0.08); overflow:hidden;">
            <table class="table table-hover mb-0" style="font-size:13px;">
                <thead style="background:#f1f1f1;">
                    <tr>
                        <th style="padding:12px 14px;">#</th>
                        <th style="padding:12px 14px;">Customer ID</th>
                        <th style="padding:12px 14px;">Order</th>
                        <th style="padding:12px 14px;">Customer</th>
                        <th style="padding:12px 14px;">Authorized By</th>
                        <th style="padding:12px 14px;">Date</th>
                        <th style="padding:12px 14px;" class="text-end">Subtotal</th>
                        <th style="padding:12px 14px; background:#e8f5e9;" class="text-end">Discount</th>
                        <th style="padding:12px 14px;" class="text-end">Final Amount</th>
                        <th style="padding:12px 14px;">Status</th>
                        <th style="padding:12px 14px; width:40px;"></th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="filteredOrders" t-as="order" t-key="order.id">
                        <!-- Main row -->
                        <tr style="cursor:pointer;"
                            t-att-class="state.expandedId === order.id ? 'table-active' : ''"
                            t-on-click="() => this.onToggleDetail(order.id)">
                            <td style="padding:10px 14px;">
                                <t t-esc="order_index + 1"/>
                            </td>
                            <td style="padding:10px 14px;">
                                <span style="background:#714B67; color:#fff; padding:3px 12px;
                                             border-radius:4px; font-weight:700; font-size:12px;
                                             letter-spacing:0.5px; cursor:pointer;"
                                      t-on-click.stop="() => this.onToggleDetail(order.id)">
                                    <t t-esc="order.customer_code or 'N/A'"/>
                                </span>
                            </td>
                            <td style="padding:10px 14px; font-weight:600;">
                                <t t-esc="order.name"/>
                            </td>
                            <td style="padding:10px 14px;">
                                <t t-esc="order.partner_id and order.partner_id[1] or '-'"/>
                            </td>
                            <td style="padding:10px 14px; color:#555;">
                                <t t-esc="order.discount_authorized_by or '-'"/>
                            </td>
                            <td style="padding:10px 14px;">
                                <t t-esc="formatDate(order.date_order)"/>
                            </td>
                            <td style="padding:10px 14px;" class="text-end">
                                <t t-esc="formatMoney(order.subtotal)"/>
                            </td>
                            <td style="padding:10px 14px; background:#e8f5e9; font-weight:700; color:#2e7d32;" class="text-end">
                                - <t t-esc="formatMoney(order.discount_amount)"/>
                            </td>
                            <td style="padding:10px 14px; font-weight:600;" class="text-end">
                                <t t-esc="formatMoney(order.total_amount)"/>
                            </td>
                            <td style="padding:10px 14px;">
                                <span t-att-class="getStatusClass(order.state)">
                                    <t t-esc="getStatusLabel(order.state)"/>
                                </span>
                            </td>
                            <td style="padding:10px 14px; text-align:center;">
                                <i t-att-class="state.expandedId === order.id
                                    ? 'fa fa-chevron-up text-muted'
                                    : 'fa fa-chevron-down text-muted'"/>
                            </td>
                        </tr>

                        <!-- ═══ EXPANDED DISCOUNT DETAIL PANEL ═══ -->
                        <tr t-if="state.expandedId === order.id">
                            <td colspan="11" style="padding:0; background:#fafafa;">
                                <div style="padding:20px 28px; border-top:2px solid #28a745;">

                                    <!-- Authorized Person Info -->
                                    <div class="row g-3 mb-3">
                                        <div class="col-md-4">
                                            <div style="background:#fff; border-radius:8px; padding:14px;
                                                        border:1px solid #eee;">
                                                <h6 style="color:#2e7d32; margin-bottom:10px; font-weight:700;">
                                                    Authorized Person
                                                </h6>
                                                <div style="font-size:13px; line-height:1.8;">
                                                    <div><strong>Name:</strong>
                                                        <t t-esc="order.discount_authorized_by or '-'"/></div>
                                                    <div><strong>Customer ID:</strong>
                                                        <span style="background:#714B67; color:#fff; padding:1px 8px;
                                                                     border-radius:3px; font-size:11px; font-weight:700;">
                                                            <t t-esc="order.customer_code or 'N/A'"/>
                                                        </span>
                                                    </div>
                                                    <div><strong>Order:</strong>
                                                        <t t-esc="order.name"/></div>
                                                    <div><strong>Total Discount:</strong>
                                                        <span style="color:#2e7d32; font-weight:700; font-size:15px;">
                                                            <t t-esc="formatMoney(order.discount_amount)"/>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div style="background:#fff; border-radius:8px; padding:14px;
                                                        border:1px solid #eee; text-align:center;">
                                                <h6 style="color:#2e7d32; margin-bottom:10px; font-weight:700;">
                                                    Authorizer Photo
                                                </h6>
                                                <t t-if="order.discount_auth_photo">
                                                    <img t-att-src="getImageSrc(order.discount_auth_photo)"
                                                         style="max-width:160px; max-height:160px; border-radius:8px;
                                                                border:2px solid #ddd; cursor:pointer;
                                                                transition: transform 0.2s, box-shadow 0.2s;"
                                                         class="rental_popup_img"
                                                         t-on-click.stop="(ev) => this.onImageClick(ev, order.discount_auth_photo, false)"
                                                         alt="Authorizer Photo"/>
                                                    <div style="font-size:11px; color:#888; margin-top:4px;">Click to enlarge</div>
                                                </t>
                                                <t t-else="">
                                                    <div style="color:#aaa; padding:30px 0;">
                                                        <i class="fa fa-camera" style="font-size:40px;"/>
                                                        <div style="font-size:12px; margin-top:6px;">No photo</div>
                                                    </div>
                                                </t>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div style="background:#fff; border-radius:8px; padding:14px;
                                                        border:1px solid #eee; text-align:center;">
                                                <h6 style="color:#2e7d32; margin-bottom:10px; font-weight:700;">
                                                    Authorizer Signature
                                                </h6>
                                                <t t-if="order.discount_auth_signature">
                                                    <img t-att-src="getImageSrc(order.discount_auth_signature)"
                                                         style="max-width:200px; max-height:120px; border-radius:4px;
                                                                border:1px solid #ddd; cursor:pointer;
                                                                transition: transform 0.2s, box-shadow 0.2s;"
                                                         class="rental_popup_img"
                                                         t-on-click.stop="(ev) => this.onImageClick(ev, order.discount_auth_signature, true)"
                                                         alt="Authorizer Signature"/>
                                                    <div style="font-size:11px; color:#888; margin-top:4px;">Click to enlarge</div>
                                                </t>
                                                <t t-else="">
                                                    <div style="color:#aaa; padding:30px 0;">
                                                        <i class="fa fa-pencil" style="font-size:40px;"/>
                                                        <div style="font-size:12px; margin-top:6px;">No signature</div>
                                                    </div>
                                                </t>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Discount Breakdown Table -->
                                    <div style="background:#fff; border-radius:8px; padding:14px;
                                                border:1px solid #eee; margin-bottom:12px;">
                                        <h6 style="color:#2e7d32; margin-bottom:10px; font-weight:700;">
                                            Discount Breakdown
                                        </h6>
                                        <table class="table table-sm table-bordered mb-0" style="font-size:12px;">
                                            <thead style="background:#f8f8f8;">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Tool</th>
                                                    <th>Serial No.</th>
                                                    <th class="text-end">Rental Cost</th>
                                                    <th class="text-end">Late Fee</th>
                                                    <th class="text-end">Damage</th>
                                                    <th>Disc. Type</th>
                                                    <th class="text-end">Disc. Value</th>
                                                    <th class="text-end" style="background:#e8f5e9;">Discount</th>
                                                    <th class="text-end" style="font-weight:700;">Final Amount</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr t-foreach="state.expandedLines" t-as="line" t-key="line.id">
                                                    <td><t t-esc="line_index + 1"/></td>
                                                    <td><t t-esc="line.product_id and line.product_id[1] or '-'"/></td>
                                                    <td><t t-esc="line.serial_number or '-'"/></td>
                                                    <td class="text-end"><t t-esc="formatMoney(line.rental_cost)"/></td>
                                                    <td class="text-end"
                                                        t-att-style="line.late_fee_amount ? 'color:#dc3545;font-weight:600;' : ''">
                                                        <t t-esc="formatMoney(line.late_fee_amount)"/></td>
                                                    <td class="text-end"
                                                        t-att-style="line.damage_charge ? 'color:#dc3545;font-weight:600;' : ''">
                                                        <t t-esc="formatMoney(line.damage_charge)"/></td>
                                                    <td>
                                                        <t t-if="line.discount_type">
                                                            <span t-att-class="line.discount_type === 'percentage'
                                                                ? 'badge bg-info' : 'badge bg-secondary'">
                                                                <t t-esc="getDiscountTypeLabel(line.discount_type)"/>
                                                            </span>
                                                        </t>
                                                        <t t-else="">-</t>
                                                    </td>
                                                    <td class="text-end">
                                                        <t t-esc="formatDiscountValue(line)"/></td>
                                                    <td class="text-end"
                                                        style="background:#e8f5e9; color:#2e7d32; font-weight:700;">
                                                        <t t-if="line.discount_line_amount">
                                                            - <t t-esc="formatMoney(line.discount_line_amount)"/>
                                                        </t>
                                                        <t t-else="">$ 0.00</t>
                                                    </td>
                                                    <td class="text-end" style="font-weight:700;">
                                                        <t t-esc="formatMoney(line.total_cost)"/></td>
                                                </tr>
                                                <tr t-if="!state.expandedLines.length">
                                                    <td colspan="10" class="text-center text-muted">No tools found</td>
                                                </tr>
                                            </tbody>
                                            <tfoot t-if="state.expandedLines.length">
                                                <tr style="background:#e8f5e9; font-weight:700;">
                                                    <td colspan="8" class="text-end"
                                                        style="color:#2e7d32; font-size:13px;">
                                                        Total Discount:
                                                    </td>
                                                    <td class="text-end"
                                                        style="color:#2e7d32; font-size:14px; background:#c8e6c9;">
                                                        - <t t-esc="formatMoney(order.discount_amount)"/>
                                                    </td>
                                                    <td class="text-end" style="font-size:14px;">
                                                        <t t-esc="formatMoney(order.total_amount)"/>
                                                    </td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>

                                    <!-- Open order button -->
                                    <div class="text-end">
                                        <button class="btn btn-sm btn-outline-success"
                                                t-on-click.stop="() => this.onOpenOrder(order.id)">
                                            <i class="fa fa-external-link me-1"/>
                                            Open Full Order
                                        </button>
                                    </div>

                                </div>
                            </td>
                        </tr>
                    </t>
                    <!-- Empty state -->
                    <tr t-if="!filteredOrders.length">
                        <td colspan="11" class="text-center text-muted" style="padding:40px;">
                            <i class="fa fa-tag" style="font-size:40px; margin-bottom:10px; display:block;"/>
                            No discounted orders found.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>

    <!-- ═══ FULLSCREEN IMAGE POPUP ═══ -->
    <div t-if="state.popupVisible"
         t-att-style="popupOverlayStyle"
         t-on-click="onOverlayClick">
        <div style="position:relative; max-width:90vw; max-height:90vh;">
            <img t-att-src="state.popupSrc"
                 style="max-width:90vw; max-height:85vh; border-radius:10px;
                        box-shadow:0 8px 40px rgba(0,0,0,0.4); cursor:default;"
                 t-on-click.stop="() => {}"/>
            <button t-on-click.stop="onClosePopup"
                    t-att-style="'position:absolute; top:-14px; right:-14px; border:none; ' +
                        'border-radius:50%; width:36px; height:36px; font-size:18px; ' +
                        'cursor:pointer; display:flex; align-items:center; justify-content:center; ' +
                        'box-shadow:0 2px 8px rgba(0,0,0,0.3); background:#fff; color:#333;'">
                <i class="fa fa-times"/>
            </button>
        </div>
    </div>

</div>
</t>
</templates>
