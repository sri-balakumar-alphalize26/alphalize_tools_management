<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ ROOT MENU ═══ -->
    <menuitem id="menu_rental_root"
              name="Tools Rental"
              web_icon="tools_rental_management,static/description/icon.png"
              sequence="45"/>

    <!-- ═══ OPERATIONS ═══ -->
    <menuitem id="menu_rental_operations"
              name="Operations"
              parent="menu_rental_root"
              sequence="10"/>

    <menuitem id="menu_rental_orders"
              name="Rental Orders"
              parent="menu_rental_operations"
              action="action_rental_order"
              sequence="10"/>

    <menuitem id="menu_rental_orders_all"
              name="All Orders"
              parent="menu_rental_operations"
              action="action_rental_order_all"
              sequence="15"/>

    <menuitem id="menu_rental_timesheet"
              name="Timesheet / Log"
              parent="menu_rental_operations"
              action="action_rental_timesheet"
              sequence="20"/>

    <!-- ═══ TOOLS ═══ -->
    <menuitem id="menu_rental_tools"
              name="Tools &amp; Equipment"
              parent="menu_rental_root"
              sequence="20"/>

    <menuitem id="menu_rental_products"
              name="Products"
              parent="menu_rental_tools"
              action="action_rental_products"
              sequence="10"/>

    <menuitem id="menu_generate_serials"
              name="+ Generate Serialized Products"
              parent="menu_rental_tools"
              action="action_rental_generate_serials"
              sequence="11"/>

    <menuitem id="menu_mark_all_rental"
              name="✔ Mark All for Rental"
              parent="menu_rental_tools"
              action="action_mark_all_rental_wizard"
              sequence="12"/>

    <menuitem id="menu_unmark_all_rental"
              name="✘ Remove All from Rental"
              parent="menu_rental_tools"
              action="action_unmark_all_rental_wizard"
              sequence="13"/>

    <menuitem id="menu_sync_products_to_rental"
              name="⟳ Sync All Products → Tools"
              parent="menu_rental_tools"
              action="action_sync_all_products_wizard"
              sequence="15"/>

    <menuitem id="menu_rental_tool_list"
              name="Rental Tools (Internal)"
              parent="menu_rental_tools"
              action="action_rental_tool"
              sequence="20"
              groups="base.group_no_one"/>

    <menuitem id="menu_rental_tool_categories"
              name="Categories"
              parent="menu_rental_tools"
              action="action_rental_category_dashboard"
              sequence="30"/>

    <!-- ═══ PRICING ═══ -->
    <menuitem id="menu_rental_pricing"
              name="Pricing"
              parent="menu_rental_root"
              sequence="30"/>

    <menuitem id="menu_rental_pricing_rules"
              name="Pricing Rules"
              parent="menu_rental_pricing"
              action="action_rental_pricing_dashboard"
              sequence="10"/>

    <menuitem id="menu_rental_pricing_templates"
              name="Pricing Templates"
              parent="menu_rental_pricing"
              action="action_rental_pricing_template"
              sequence="20"/>

    <!-- ═══ REPORTING ═══ -->
    <menuitem id="menu_rental_reporting"
              name="Reporting"
              parent="menu_rental_root"
              sequence="40"/>

    <menuitem id="menu_rental_dashboard"
              name="Dashboard"
              parent="menu_rental_reporting"
              action="action_rental_dashboard"
              sequence="10"/>

    <menuitem id="menu_rental_tool_report"
              name="Tool Availability"
              parent="menu_rental_reporting"
              action="action_rental_tool_report_dashboard"
              sequence="20"/>

    <menuitem id="menu_rental_order_report"
              name="Order Reports"
              parent="menu_rental_reporting"
              action="action_rental_order_report_dashboard"
              sequence="30"/>

    <menuitem id="menu_rental_discount_report"
              name="Discount Details"
              parent="menu_rental_reporting"
              action="action_rental_discount_report_dashboard"
              sequence="40"/>
</odoo>
