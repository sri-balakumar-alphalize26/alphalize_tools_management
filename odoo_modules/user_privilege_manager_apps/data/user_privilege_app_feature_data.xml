        <field name="parent_id" ref="rental_tile_expenses"/>
        <field name="sequence">180</field>
    </record>
    <record id="rental_feat_expenses_edit" model="app.feature.app">
        <field name="feature_key">expenses.edit</field>
        <field name="name">Edit Expense</field>
        <field name="description">Show the Save button on a draft expense form.</field>
        <field name="parent_id" ref="rental_tile_expenses"/>
        <field name="sequence">181</field>
    </record>
    <record id="rental_feat_expenses_delete" model="app.feature.app">
        <field name="feature_key">expenses.delete</field>
        <field name="name">Delete Expense</field>
        <field name="description">Show the Delete button on the expense form.</field>
        <field name="parent_id" ref="rental_tile_expenses"/>
        <field name="sequence">182</field>
    </record>
    <record id="rental_feat_expenses_submit" model="app.feature.app">
        <field name="feature_key">expenses.submit</field>
        <field name="name">Submit Expense</field>
        <field name="description">Show the Submit button on a draft expense.</field>
        <field name="parent_id" ref="rental_tile_expenses"/>
        <field name="sequence">183</field>
    </record>
    <record id="rental_feat_expenses_approve" model="app.feature.app">
        <field name="feature_key">expenses.approve</field>
        <field name="name">Approve Expense</field>
        <field name="description">Show the Approve button on submitted expenses (manager action).</field>
        <field name="parent_id" ref="rental_tile_expenses"/>
        <field name="sequence">184</field>
    </record>
    <record id="rental_feat_expenses_refuse" model="app.feature.app">
        <field name="feature_key">expenses.refuse</field>
        <field name="name">Refuse Expense</field>
        <field name="description">Show the Refuse button on submitted/approved expenses (manager action).</field>
        <field name="parent_id" ref="rental_tile_expenses"/>
        <field name="sequence">185</field>
