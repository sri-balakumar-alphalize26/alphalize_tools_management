<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════
         SECTION 1: "Products from Inventory" inside Tools Rental module
         ════════════════════════════════════════════════════════════════ -->

    <!-- ═══ LIST VIEW — Rental-focused product list ═══ -->
    <record id="view_rental_product_tree" model="ir.ui.view">
        <field name="name">product.product.rental.tree</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <list js_class="rental_product_list">
                <field name="default_code" string="Serial No."/>
                <field name="name" string="Product"/>
                <field name="list_price" string="Price/Day" widget="monetary"/>
                <field name="rental_late_fee_per_day" string="Late Fee/Day" widget="monetary"/>
                <field name="rental_on_hand" string="On Hand" readonly="1"/>
                <field name="rental_state" string="Status" widget="badge"
                       decoration-success="rental_state == 'available'"
                       decoration-danger="rental_state == 'rented'"
                       decoration-warning="rental_state == 'maintenance'"
                       optional="show"/>
                <field name="rental_categ_id" string="Category" optional="show"/>
                <field name="rental_total_rentals" string="Rentals" optional="show"/>
                <field name="rental_revenue" string="Revenue" optional="hide"/>
                <field name="is_rental" string="Rental" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ═══ FORM VIEW — Product form with rental details ═══ -->
    <record id="view_rental_product_form" model="ir.ui.view">
        <field name="name">product.product.rental.form</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_rental_tool" type="object"
                            string="Create Rental Tool"
                            class="btn-primary"
                            invisible="rental_tool_id"/>
                    <button name="action_view_rental_tool" type="object"
                            string="Open Rental Tool"
                            class="btn-secondary"
                            invisible="not rental_tool_id"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_rental_tool" type="object"
                                class="oe_stat_button" icon="fa-wrench"
                                invisible="not rental_tool_id">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="rental_total_rentals"/>
                                </span>
                                <span class="o_stat_text">Rentals</span>
                            </div>
                        </button>
                    </div>
                    <field name="image_1920" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Product Name"/></h1>
                    </div>
                    <group>
                        <group string="Product Info">
                            <field name="default_code" string="Serial No."/>
                            <field name="barcode"/>
                            <field name="list_price" string="Price / Day"/>
                            <field name="rental_late_fee_per_day"/>
                            <field name="rental_on_hand" string="On Hand" readonly="1"/>
                        </group>
                        <group string="Rental Configuration">
                            <field name="is_rental" widget="boolean_toggle"/>
                            <field name="rental_categ_id"/>
                            <field name="rental_price_per_day"/>
                            <field name="rental_late_fee_per_day"/>
                            <field name="rental_location"/>
                            <field name="rental_tool_id" readonly="1"/>
                        </group>
                    </group>
                    <group invisible="not rental_tool_id">
                        <group string="Rental Status">
                            <field name="rental_total_qty"/>
                            <field name="rental_available_qty"/>
                            <field name="rental_state" widget="badge"
                                   decoration-success="rental_state == 'available'"
                                   decoration-warning="rental_state == 'maintenance'"
                                   decoration-danger="rental_state == 'rented'"/>
                        </group>
                        <group string="Rental Revenue">
                            <field name="rental_total_rentals"/>
                            <field name="rental_revenue"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══ KANBAN VIEW ═══ -->
    <record id="view_rental_product_kanban" model="ir.ui.view">
        <field name="name">product.product.rental.kanban</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <kanban js_class="rental_product_kanban">
                <field name="name"/>
                <field name="default_code"/>
                <field name="list_price"/>
                <field name="rental_late_fee_per_day"/>
                <field name="is_rental"/>
                <field name="rental_available_qty"/>
                <field name="rental_total_qty"/>
                <field name="rental_state"/>
                <field name="image_128"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card" class="o_rental_tool_card">
                        <!-- Image section -->
                        <div class="o_rental_card_image">
                            <field name="image_128" widget="image"
                                   options="{'preview_image': 'image_128'}"/>
                            <!-- Status badge overlay -->
                            <div class="o_rental_card_badge">
                                <t t-if="record.is_rental.raw_value">
                                    <t t-if="record.rental_state.raw_value == 'rented'">
                                        <span class="badge text-bg-danger">Checked Out</span>
                                    </t>
                                    <t t-elif="record.rental_state.raw_value == 'maintenance'">
                                        <span class="badge text-bg-warning">Maintenance</span>
                                    </t>
                                    <t t-else="">
                                        <span class="badge text-bg-success">Available</span>
                                    </t>
                                </t>
                                <t t-else="">
                                    <span class="badge text-bg-secondary">Not Rental</span>
                                </t>
                            </div>
                        </div>
                        <!-- Details section -->
                        <div class="o_rental_card_body">
                            <strong class="o_rental_card_title">
                                <field name="name"/>
                            </strong>
                            <div t-if="record.default_code.value"
                                 class="o_rental_card_serial">
                                <i class="fa fa-barcode me-1"/>
                                <field name="default_code"/>
                            </div>
                            <div class="o_rental_card_prices">
                                <div class="o_rental_card_price">
                                    <field name="list_price" widget="monetary"/>
                                    <span class="o_rental_card_price_label">/day</span>
                                </div>
                                <div t-if="record.rental_late_fee_per_day.raw_value > 0"
                                     class="o_rental_card_late">
                                    Late: <field name="rental_late_fee_per_day" widget="monetary"/>/day
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══ SEARCH VIEW ═══ -->
    <record id="view_rental_product_search" model="ir.ui.view">
        <field name="name">product.product.rental.search</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Product"
                       filter_domain="['|', '|', ('name', 'ilike', self), ('default_code', 'ilike', self), ('barcode', 'ilike', self)]"/>
                <field name="categ_id"/>
                <field name="rental_categ_id"/>
                <field name="barcode"/>
                <separator/>
                <filter name="rental_enabled" string="Rental Enabled"
                        domain="[('is_rental', '=', True)]"/>
                <filter name="not_rental" string="Not in Rental"
                        domain="[('is_rental', '=', False)]"/>
                <separator/>
                <filter name="storable" string="Storable"
                        domain="[('type', '=', 'product')]"/>
                <filter name="consumable" string="Consumable"
                        domain="[('type', '=', 'consu')]"/>
                <separator/>
                <group>
                    <filter name="group_category" string="Product Category"
                            context="{'group_by': 'categ_id'}"/>
                    <filter name="group_rental_categ" string="Rental Category"
                            context="{'group_by': 'rental_categ_id'}"/>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ ACTION ═══ -->
    <record id="action_rental_inventory_products" model="ir.actions.act_window">
        <field name="name">Products from Inventory</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_rental_product_tree')}),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_rental_product_kanban')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_rental_product_form')})]"/>
        <field name="search_view_id" ref="view_rental_product_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No products found
            </p>
            <p>
                All inventory products are listed here. Enable "Available for Rental"
                to make a product selectable in rental orders. You can set rental
                category, daily price, and storage location.
            </p>
        </field>
    </record>


    <!-- ════════════════════════════════════════════════════════════════
         SECTION 2: "Rental" tab on standard Inventory Product form
         Inherits product.product form to add rental configuration
         ════════════════════════════════════════════════════════════════ -->

    <!-- ═══ INHERIT: product.product form — add Rental tab ═══ -->
    <record id="view_product_product_form_inherit_rental" model="ir.ui.view">
        <field name="name">product.product.form.inherit.rental</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <!-- Add stat button for rental -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_rental_tool" type="object"
                        class="oe_stat_button" icon="fa-wrench"
                        invisible="not rental_tool_id">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="rental_total_rentals"/>
                        </span>
                        <span class="o_stat_text">Rentals</span>
                    </div>
                </button>
            </xpath>
            <!-- Add Rental tab in notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Rental" name="rental_tab">
                    <group>
                        <group string="Rental Configuration">
                            <field name="is_rental" widget="boolean_toggle"/>
                            <field name="rental_categ_id"/>
                            <field name="rental_price_per_day"/>
                            <field name="rental_late_fee_per_day"/>
                            <field name="rental_location"/>
                        </group>
                        <group string="Rental Status" invisible="not rental_tool_id">
                            <field name="rental_tool_id" readonly="1"/>
                            <field name="rental_total_qty"/>
                            <field name="rental_available_qty"/>
                            <field name="rental_state" widget="badge"
                                   decoration-success="rental_state == 'available'"
                                   decoration-warning="rental_state == 'maintenance'"
                                   decoration-danger="rental_state == 'rented'"/>
                            <field name="rental_revenue"/>
                        </group>
                    </group>
                    <group invisible="rental_tool_id">
                        <div class="alert alert-info" role="alert">
                            <strong>💡 Tip:</strong> Enable "Available for Rental" and save to make this product
                            available in the Tools Rental module. A rental tool will be automatically created
                            when this product is first added to a rental order.
                            <br/><br/>
                            <button name="action_create_rental_tool" type="object"
                                    string="Create Rental Tool Now" class="btn-primary btn-sm"/>
                        </div>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ═══ INHERIT: product.template form — add Rental tab ═══ -->
    <record id="view_product_template_form_inherit_rental" model="ir.ui.view">
        <field name="name">product.template.form.inherit.rental</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Rental" name="rental_tab">
                    <group>
                        <group string="Rental Configuration">
                            <field name="is_rental" widget="boolean_toggle"/>
                            <field name="rental_categ_id"/>
                            <field name="rental_price_per_day"/>
                            <field name="rental_late_fee_per_day"/>
                            <field name="rental_location"/>
                        </group>
                        <group string="Info">
                            <div class="alert alert-info" role="alert">
                                <strong>💡</strong> Set rental category and pricing here.
                                The rental tool will be auto-created when this product
                                is first added to a rental order.
                            </div>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
