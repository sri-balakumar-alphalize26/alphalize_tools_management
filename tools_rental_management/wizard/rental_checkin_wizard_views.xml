<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rental_checkin_wizard_form" model="ir.ui.view">
        <field name="name">rental.checkin.wizard.form</field>
        <field name="model">rental.checkin.wizard</field>
        <field name="arch" type="xml">
            <form string="Check-In Tools">
                <field name="is_partial" invisible="1"/>
                <field name="advance_amount" invisible="1"/>
                <group>
                    <group>
                        <field name="order_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="checkout_date" readonly="1"/>
                        <field name="checkin_date"/>
                        <field name="total_days_display" readonly="1" string="Duration"/>
                        <field name="total_days" invisible="1"/>
                        <field name="is_late" invisible="1"/>
                        <field name="return_advance"
                               invisible="advance_amount == 0"/>
                    </group>
                </group>
                <!-- Late Return Warning -->
                <div class="alert alert-warning" role="alert"
                     invisible="not is_late"
                     style="margin-bottom: 10px;">
                    <strong>Late Return</strong> — Customer has exceeded the planned rental duration. Late fees will apply.
                </div>
                <separator string="Tools"/>
                <field name="line_ids">
                    <list editable="bottom">
                        <field name="order_line_id" column_invisible="1"/>
                        <field name="tool_id" column_invisible="1"/>
                        <field name="product_id" column_invisible="1"/>
                        <field name="tool_name" string="Tool" readonly="1"/>
                        <field name="serial_number" string="Serial No." readonly="1"/>
                        <field name="condition" string="Condition" required="1"/>
                        <field name="quantity" column_invisible="1"/>
                        <field name="returned_so_far" column_invisible="1"/>
                        <field name="pending_qty" column_invisible="1"/>
                        <field name="return_qty" column_invisible="1"/>
                        <field name="duration_display" string="Duration" readonly="1"/>
                        <field name="extra_days" string="Extra Days" readonly="1"
                               decoration-danger="extra_days > 0"/>
                        <field name="late_fee_per_day" string="Late Fee/Day" readonly="1"/>
                        <field name="late_fee" string="Late Fee" readonly="1"
                               decoration-danger="late_fee > 0"/>
                        <field name="tool_image" widget="image"
                               options="{'size': [80, 60]}" optional="show"
                               string="Tool Photo"/>
                        <field name="damage_note"/>
                        <field name="damage_charge"/>
                        <field name="discount_display" string="Discount"
                               readonly="1"
                               decoration-success="discount_line_amount > 0"/>
                        <field name="discount_line_amount" string="Disc. Amt"
                               readonly="1"
                               decoration-success="discount_line_amount > 0"/>
                        <field name="planned_days" column_invisible="1"/>
                        <field name="currency_id" column_invisible="1"/>
                    </list>
                </field>
                <group>
                    <group></group>
                    <group>
                        <field name="total_late_fee" readonly="1"
                               invisible="total_late_fee == 0"
                               string="Total Late Fees"/>
                        <field name="total_damage_charge" readonly="1"/>
                        <field name="total_discount" readonly="1"
                               invisible="total_discount == 0"
                               string="Total Discount"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <!-- Advance / Balance Section (only if advance was collected) -->
                <div invisible="advance_amount == 0">
                    <separator string="Advance Payment Summary"/>
                    <group>
                        <group>
                            <field name="total_bill" readonly="1"
                                   string="Total Bill"/>
                            <field name="advance_amount" readonly="1"
                                   string="Advance Collected at Checkout"/>
                            <field name="return_advance" string="Return Advance to Customer?"/>
                        </group>
                        <group>
                            <field name="balance_due" readonly="1"
                                   string="Balance Due from Customer"
                                   invisible="return_advance"
                                   class="oe_subtotal_footer_separator"
                                   decoration-danger="balance_due > 0"/>
                            <div invisible="not return_advance" class="text-muted">
                                <em>Advance will be returned to the customer.</em>
                            </div>
                        </group>
                    </group>
                </div>
                <separator string="Customer Signature (Required)"/>
                <group>
                    <field name="checkin_customer_signature" widget="signature"
                           nolabel="1" string="Customer Signature"/>
                </group>
                <separator string="Authority Signature (Required)"/>
                <group>
                    <field name="customer_name" placeholder="Signer name..."
                           required="1" string="Signer Name"/>
                </group>
                <group>
                    <field name="customer_signature" widget="signature" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_save_partial" type="object"
                            string="Save (Partial Return)" class="btn-warning"
                            invisible="not is_partial"/>
                    <button name="action_confirm_checkin" type="object"
                            string="Confirm Check-In" class="btn-primary"
                            invisible="is_partial"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
