<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_rental_agreement">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">TOOLS RENTAL AGREEMENT</h2>
                        <h4 class="text-center text-muted">
                            <span t-field="doc.name"/>
                        </h4>
                        <br/>

                        <!-- Parties -->
                        <div class="row">
                            <div class="col-6">
                                <strong>Rental Company:</strong><br/>
                                <span t-field="doc.company_id.partner_id.name"/><br/>
                                <span t-field="doc.company_id.partner_id.street"/><br/>
                                <span t-field="doc.company_id.partner_id.city"/>
                                <span t-field="doc.company_id.partner_id.zip"/><br/>
                                Phone: <span t-field="doc.company_id.phone"/>
                            </div>
                            <div class="col-6">
                                <strong>Customer:</strong><br/>
                                <span t-field="doc.partner_id.name"/><br/>
                                <span t-field="doc.partner_id.street"/><br/>
                                <span t-field="doc.partner_id.city"/>
                                <span t-field="doc.partner_id.zip"/><br/>
                                Phone: <span t-field="doc.partner_id.phone"/>
                            </div>
                        </div>
                        <br/>

                        <!-- Rental Details -->
                        <table class="table table-sm">
                            <tr>
                                <td><strong>Order Date:</strong></td>
                                <td><span t-field="doc.date_order" t-options='{"widget": "date"}'/></td>
                                <td><strong>Billing Period:</strong></td>
                                <td><span t-field="doc.rental_period_type"/></td>
                            </tr>
                            <tr>
                                <td><strong>Planned Check-Out:</strong></td>
                                <td><span t-field="doc.date_planned_checkout"/></td>
                                <td><strong>Planned Return:</strong></td>
                                <td><span t-field="doc.date_planned_checkin"/></td>
                            </tr>
                            <tr>
                                <td><strong>Duration:</strong></td>
                                <td><span t-field="doc.rental_duration"/>
                                    <span t-field="doc.rental_period_type"/>(s)</td>
                                <td><strong>Advance:</strong></td>
                                <td><span t-field="doc.advance_amount"/></td>
                            </tr>
                        </table>

                        <!-- Tools Table -->
                        <h5>Rented Tools / Equipment</h5>
                        <table class="table table-bordered table-sm">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Tool</th>
                                    <th>Category</th>
                                    <th>Condition</th>
                                    <th>Unit Price</th>
                                    <th>Duration</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="idx" t-value="0"/>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <t t-set="idx" t-value="idx + 1"/>
                                    <td><t t-out="idx"/></td>
                                    <td><span t-field="line.tool_id.name"/></td>
                                    <td><span t-field="line.tool_category_id.name"/></td>
                                    <td><span t-field="line.tool_condition_out"/></td>
                                    <td><span t-field="line.unit_price"/></td>
                                    <td><span t-field="line.actual_duration_display"/></td>
                                    <td class="text-end">
                                        <span t-field="line.total_cost"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Totals -->
                        <div class="row">
                            <div class="col-6"/>
                            <div class="col-6">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Subtotal:</strong></td>
                                        <td class="text-end"><span t-field="doc.subtotal"/></td>
                                    </tr>
                                    <tr t-if="doc.late_fee">
                                        <td>Late Fees:</td>
                                        <td class="text-end"><span t-field="doc.late_fee"/></td>
                                    </tr>
                                    <tr t-if="doc.damage_charges">
                                        <td>Damage Charges:</td>
                                        <td class="text-end"><span t-field="doc.damage_charges"/></td>
                                    </tr>
                                    <tr t-if="doc.discount_amount">
                                        <td>Discount:</td>
                                        <td class="text-end">-<span t-field="doc.discount_amount"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>TOTAL:</strong></td>
                                        <td class="text-end"><strong><span t-field="doc.total_amount"/></strong></td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                        <br/>

                        <!-- Terms -->
                        <t t-if="doc.terms">
                            <h5>Terms &amp; Conditions</h5>
                            <div t-field="doc.terms"/>
                        </t>
                        <br/>

                        <!-- Signatures -->
                        <div class="row mt-5">
                            <div class="col-5 text-center">
                                <hr/>
                                <strong>Company Representative</strong><br/>
                                <span t-field="doc.user_id.name"/>
                            </div>
                            <div class="col-2"/>
                            <div class="col-5 text-center">
                                <hr/>
                                <strong>Customer</strong><br/>
                                <span t-field="doc.partner_id.name"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
