<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="tools_rental_management.RentalToolKanbanView" t-inherit="web.KanbanView" t-inherit-mode="primary">
        <xpath expr="//Layout/t[@t-set-slot='control-panel-create-button']" position="inside">
            <button type="button" class="btn btn-primary btn-sm ms-1"
                    t-on-click="() => this.onGenerateSerials()">
                <i class="fa fa-cogs me-1"/>Generate Serialized Products
            </button>
            <span class="ms-2"/>
            <button type="button" class="btn btn-outline-dark btn-sm"
                    t-on-click="() => this.onSelectAll()">
                <i class="fa fa-check-square-o me-1"/>Select All
            </button>
            <button type="button" class="btn btn-danger btn-sm ms-1"
                    t-on-click="() => this.onDeleteSelected()">
                <i class="fa fa-trash me-1"/>Delete
            </button>
        </xpath>
    </t>

</templates>
