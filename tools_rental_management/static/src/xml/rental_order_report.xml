<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="tools_rental_management.RentalOrderReport">
<div class="o_action o_rental_order_report" style="background:#f8f9fa; height:100%; overflow-y:scroll;">

    <!-- ═══ HEADER ═══ -->
    <div style="background:#714B67; color:#fff; padding:16px 24px;
                position:sticky; top:0; z-index:100;
                display:flex; align-items:center; justify-content:space-between;">
        <h3 style="margin:0; font-weight:700;">Order Reports</h3>
        <span class="text-white-50" style="font-size:13px;">
            Showing <t t-esc="filteredOrders.length"/> orders
        </span>
    </div>

    <div style="padding:20px 24px;">

        <!-- ═══ SUMMARY CARDS ═══ -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div style="background:#fff; border-radius:10px; padding:18px;
                            box-shadow:0 1px 4px rgba(0,0,0,0.08); border-left:4px solid #714B67;">
                    <div style="color:#888; font-size:12px; text-transform:uppercase;">Total Orders</div>
                    <div style="font-size:28px; font-weight:700; color:#714B67;">
                        <t t-esc="summaryCards.totalOrders"/>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:#fff; border-radius:10px; padding:18px;
                            box-shadow:0 1px 4px rgba(0,0,0,0.08); border-left:4px solid #f0ad4e;">
                    <div style="color:#888; font-size:12px; text-transform:uppercase;">Active Rentals</div>
                    <div style="font-size:28px; font-weight:700; color:#f0ad4e;">
                        <t t-esc="summaryCards.activeRentals"/>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:#fff; border-radius:10px; padding:18px;
                            box-shadow:0 1px 4px rgba(0,0,0,0.08); border-left:4px solid #28a745;">
                    <div style="color:#888; font-size:12px; text-transform:uppercase;">Total Revenue</div>
                    <div style="font-size:28px; font-weight:700; color:#28a745;">
                        <t t-esc="formatMoney(summaryCards.totalRevenue)"/>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div style="background:#fff; border-radius:10px; padding:18px;
                            box-shadow:0 1px 4px rgba(0,0,0,0.08); border-left:4px solid #dc3545;">
                    <div style="color:#888; font-size:12px; text-transform:uppercase;">Late Returns</div>
                    <div style="font-size:28px; font-weight:700; color:#dc3545;">
                        <t t-esc="summaryCards.lateReturns"/>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══ FILTER BAR ═══ -->
        <div style="background:#fff; border-radius:10px; padding:14px 18px;
                    box-shadow:0 1px 4px rgba(0,0,0,0.08); margin-bottom:16px;
                    display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
            <input type="text" class="form-control form-control-sm"
                   style="max-width:280px;"
                   placeholder="Search by Customer ID, Order, Name, Phone..."
                   t-on-input="onSearchInput"/>
            <select class="form-select form-select-sm" style="max-width:180px;"
                    t-on-change="onFilterStatus">
                <option value="all">All Statuses</option>
                <option value="draft">Draft</option>
                <option value="confirmed">Confirmed</option>
                <option value="checked_out">Checked Out</option>
                <option value="checked_in">Checked In</option>
                <option value="invoiced">Invoiced</option>
                <option value="cancelled">Cancelled</option>
            </select>
        </div>

        <!-- ═══ ORDERS TABLE ═══ -->
        <div style="background:#fff; border-radius:10px;
                    box-shadow:0 1px 4px rgba(0,0,0,0.08); overflow:hidden;">
            <table class="table table-hover mb-0" style="font-size:13px;">
                <thead style="background:#f1f1f1;">
                    <tr>
                        <th style="padding:12px 14px;">#</th>
                        <th style="padding:12px 14px;">Customer ID</th>
                        <th style="padding:12px 14px;">Order</th>
                        <th style="padding:12px 14px;">Customer</th>
                        <th style="padding:12px 14px;">Phone</th>
                        <th style="padding:12px 14px;">Date</th>
                        <th style="padding:12px 14px;">Status</th>
                        <th style="padding:12px 14px;" class="text-end">Amount</th>
                        <th style="padding:12px 14px; width:40px;"></th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="filteredOrders" t-as="order" t-key="order.id">
                        <!-- Main row -->
                        <tr style="cursor:pointer;"
                            t-att-class="state.expandedId === order.id ? 'table-active' : ''"
                            t-on-click="() => this.onToggleDetail(order.id)">
                            <td style="padding:10px 14px;">
                                <t t-esc="order_index + 1"/>
                            </td>
                            <td style="padding:10px 14px;">
                                <span style="background:#714B67; color:#fff; padding:3px 12px;
                                             border-radius:4px; font-weight:700; font-size:12px;
                                             letter-spacing:0.5px; cursor:pointer;"
                                      t-on-click.stop="() => this.onToggleDetail(order.id)">
                                    <t t-esc="order.customer_code or 'N/A'"/>
                                </span>
                            </td>
                            <td style="padding:10px 14px; font-weight:600;">
                                <t t-esc="order.name"/>
                            </td>
                            <td style="padding:10px 14px;">
                                <t t-esc="order.partner_id and order.partner_id[1] or '-'"/>
                            </td>
                            <td style="padding:10px 14px; color:#666;">
                                <t t-esc="order.partner_phone or '-'"/>
                            </td>
                            <td style="padding:10px 14px;">
                                <t t-esc="formatDate(order.date_order)"/>
                            </td>
                            <td style="padding:10px 14px;">
                                <span t-att-class="getStatusClass(order.state)">
                                    <t t-esc="getStatusLabel(order.state)"/>
                                </span>
                            </td>
                            <td style="padding:10px 14px; font-weight:600;" class="text-end">
                                <t t-esc="formatMoney(order.total_amount)"/>
                            </td>
                            <td style="padding:10px 14px; text-align:center;">
                                <i t-att-class="state.expandedId === order.id
                                    ? 'fa fa-chevron-up text-muted'
                                    : 'fa fa-chevron-down text-muted'"/>
                            </td>
                        </tr>

                        <!-- ═══ EXPANDED DETAIL PANEL ═══ -->
                        <tr t-if="state.expandedId === order.id">
                            <td colspan="9" style="padding:0; background:#fafafa;">
                                <div style="padding:20px 28px; border-top:2px solid #714B67;">

                                    <!-- Order info cards -->
                                    <div class="row g-3 mb-3">
                                        <div class="col-md-4">
                                            <div style="background:#fff; border-radius:8px; padding:14px;
                                                        border:1px solid #eee;">
                                                <h6 style="color:#714B67; margin-bottom:10px; font-weight:700;">
                                                    Customer Details
                                                </h6>
                                                <div style="font-size:13px; line-height:1.8;">
                                                    <div><strong>Name:</strong>
                                                        <t t-esc="order.partner_id and order.partner_id[1] or '-'"/></div>
                                                    <div><strong>Phone:</strong>
                                                        <t t-esc="order.partner_phone or '-'"/></div>
                                                    <div><strong>Email:</strong>
                                                        <t t-esc="order.partner_email or '-'"/></div>
                                                    <div><strong>Customer ID:</strong>
                                                        <span style="background:#714B67; color:#fff; padding:1px 8px;
                                                                     border-radius:3px; font-size:11px; font-weight:700;">
                                                            <t t-esc="order.customer_code or 'N/A'"/>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div style="background:#fff; border-radius:8px; padding:14px;
                                                        border:1px solid #eee;">
                                                <h6 style="color:#714B67; margin-bottom:10px; font-weight:700;">
                                                    Rental Period
                                                </h6>
                                                <div style="font-size:13px; line-height:1.8;">
                                                    <div><strong>Order Date:</strong>
                                                        <t t-esc="formatDate(order.date_order)"/></div>
                                                    <div><strong>Check-Out:</strong>
                                                        <t t-esc="formatDate(order.date_checkout)"/></div>
                                                    <div><strong>Check-In:</strong>
                                                        <t t-esc="formatDate(order.date_checkin)"/></div>
                                                    <div><strong>Planned Return:</strong>
                                                        <t t-esc="formatDate(order.date_planned_checkin)"/></div>
                                                    <div><strong>Duration:</strong>
                                                        <t t-esc="order.actual_duration_display || (order.rental_duration + ' Days')"/></div>
                                                    <div><strong>Billing:</strong>
                                                        <t t-esc="capitalize(order.rental_period_type)"/></div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div style="background:#fff; border-radius:8px; padding:14px;
                                                        border:1px solid #eee;">
                                                <h6 style="color:#714B67; margin-bottom:10px; font-weight:700;">
                                                    Financial Summary
                                                </h6>
                                                <div style="font-size:13px; line-height:1.8;">
                                                    <div><strong>Subtotal:</strong>
                                                        <t t-esc="formatMoney(order.subtotal)"/></div>
                                                    <div t-if="order.late_fee" style="color:#dc3545;">
                                                        <strong>Late Fees:</strong>
                                                        <t t-esc="formatMoney(order.late_fee)"/></div>
                                                    <div t-if="order.damage_charges" style="color:#dc3545;">
                                                        <strong>Damage Charges:</strong>
                                                        <t t-esc="formatMoney(order.damage_charges)"/></div>
                                                    <div t-if="order.discount_amount">
                                                        <strong>Discount:</strong>
                                                        -<t t-esc="formatMoney(order.discount_amount)"/></div>
                                                    <div style="border-top:1px solid #ddd; padding-top:4px; margin-top:4px;">
                                                        <strong style="font-size:15px;">Total:
                                                            <span style="color:#714B67;">
                                                                <t t-esc="formatMoney(order.total_amount)"/>
                                                            </span>
                                                        </strong>
                                                    </div>
                                                    <div><strong>Advance:</strong>
                                                        <t t-esc="formatMoney(order.advance_amount)"/>
                                                        <t t-if="order.advance_returned">
                                                            <span class="badge bg-success ms-1" style="font-size:10px;">Returned</span>
                                                        </t>
                                                    </div>
                                                    <div><strong>Responsible:</strong>
                                                        <t t-esc="order.user_id and order.user_id[1] or '-'"/></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Late warning -->
                                    <div t-if="order.is_late"
                                         style="background:#fff3cd; border:1px solid #ffc107;
                                                padding:8px 14px; border-radius:6px; margin-bottom:12px;
                                                font-size:13px;">
                                        <strong style="color:#856404;">LATE RETURN</strong>
                                        <span style="color:#856404;"> — This rental exceeded the planned return date.</span>
                                    </div>

                                    <!-- Tools table -->
                                    <div style="background:#fff; border-radius:8px; padding:14px;
                                                border:1px solid #eee; margin-bottom:12px;">
                                        <h6 style="color:#714B67; margin-bottom:10px; font-weight:700;">
                                            Tools / Equipment
                                        </h6>
                                        <table class="table table-sm table-bordered mb-0" style="font-size:12px;">
                                            <thead style="background:#f8f8f8;">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Tool</th>
                                                    <th>Serial No.</th>
                                                    <th>Out Condition</th>
                                                    <th>In Condition</th>
                                                    <th class="text-end">Price/Day</th>
                                                    <th class="text-end">Duration</th>
                                                    <th class="text-end">Rental Cost</th>
                                                    <th class="text-end">Late Fee</th>
                                                    <th class="text-end">Damage</th>
                                                    <th>Damage Note</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr t-foreach="state.expandedLines" t-as="line" t-key="line.id">
                                                    <td><t t-esc="line_index + 1"/></td>
                                                    <td><t t-esc="line.product_id and line.product_id[1] or '-'"/></td>
                                                    <td><t t-esc="line.serial_number or '-'"/></td>
                                                    <td t-att-class="getConditionClass(line.checkout_condition)">
                                                        <t t-esc="capitalize(line.checkout_condition)"/></td>
                                                    <td t-att-class="getConditionClass(line.checkin_condition)">
                                                        <t t-esc="capitalize(line.checkin_condition)"/></td>
                                                    <td class="text-end"><t t-esc="formatMoney(line.unit_price)"/></td>
                                                    <td class="text-end"><t t-esc="formatDuration(line.planned_duration)"/></td>
                                                    <td class="text-end"><t t-esc="formatMoney(line.rental_cost)"/></td>
                                                    <td class="text-end"
                                                        t-att-style="line.late_fee_amount ? 'color:red;font-weight:bold;' : ''">
                                                        <t t-esc="formatMoney(line.late_fee_amount)"/></td>
                                                    <td class="text-end"
                                                        t-att-style="line.damage_charge ? 'color:red;font-weight:bold;' : ''">
                                                        <t t-esc="formatMoney(line.damage_charge)"/></td>
                                                    <td><t t-esc="line.damage_note or '-'"/></td>
                                                </tr>
                                                <tr t-if="!state.expandedLines.length">
                                                    <td colspan="11" class="text-center text-muted">No tools found</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>

                                    <!-- Open full order button -->
                                    <div class="text-end">
                                        <button class="btn btn-sm btn-outline-primary"
                                                t-on-click.stop="() => this.onOpenOrder(order.id)">
                                            <i class="fa fa-external-link me-1"/>
                                            Open Full Order
                                        </button>
                                    </div>

                                </div>
                            </td>
                        </tr>
                    </t>
                    <!-- Empty state -->
                    <tr t-if="!filteredOrders.length">
                        <td colspan="9" class="text-center text-muted" style="padding:40px;">
                            No orders found matching your criteria.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</div>
</t>
</templates>
