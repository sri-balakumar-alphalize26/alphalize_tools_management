<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Tool Rentals app feature catalog.

        Each record is one gateable UI element. feature_key must match the
        `featureKey` used by the React Native Tools Rental app (home tiles in
        HomeScreen SECTIONS, and the action buttons inside each screen).

        noupdate="0" throughout: future catalog edits in this file apply on
        upgrade (no noupdate trap). The 19.0.5.5.1 pre-migration wipes any
        previous catalog first, so these load as the only records.
    -->
    <data noupdate="0">

    <!-- ============================================================ -->
    <!-- HOME TILES (parents) — one per HomeScreen tile               -->
    <!-- ============================================================ -->

    <!-- Operations -->
    <record id="rental_tile_new_rental" model="app.feature.app">
        <field name="feature_key">home.tile.new_rental</field>
        <field name="name">New Rental Tile</field>
        <field name="description">Home tile: open the New Rental order form.</field>
        <field name="sequence">10</field>
    </record>
    <record id="rental_tile_rental_orders" model="app.feature.app">
        <field name="feature_key">home.tile.rental_orders</field>
        <field name="name">Rental Orders Tile</field>
        <field name="description">Home tile: browse and manage rental orders.</field>
        <field name="sequence">11</field>
    </record>

    <!-- Tools &amp; Pricing -->
    <record id="rental_tile_tools" model="app.feature.app">
        <field name="feature_key">home.tile.tools</field>
        <field name="name">Tools &amp; Equipment Tile</field>
        <field name="description">Home tile: browse and manage tools / equipment.</field>
        <field name="sequence">20</field>
    </record>
    <record id="rental_tile_pricing" model="app.feature.app">
        <field name="feature_key">home.tile.pricing</field>
        <field name="name">Pricing Rules Tile</field>
        <field name="description">Home tile: manage rental pricing rules.</field>
        <field name="sequence">21</field>
    </record>
    <record id="rental_tile_tool_categories" model="app.feature.app">
        <field name="feature_key">home.tile.tool_categories</field>
        <field name="name">Tool Categories Tile</field>
        <field name="description">Home tile: view tool categories.</field>
        <field name="sequence">22</field>
    </record>
    <record id="rental_tile_tool_availability" model="app.feature.app">
        <field name="feature_key">home.tile.tool_availability</field>
        <field name="name">Tool Availability Tile</field>
        <field name="description">Home tile: view tool availability and export the report.</field>
        <field name="sequence">23</field>
    </record>

    <!-- Customers -->
    <record id="rental_tile_customers" model="app.feature.app">
        <field name="feature_key">home.tile.customers</field>
        <field name="name">Customers Tile</field>
        <field name="description">Home tile: customer directory and management.</field>
        <field name="sequence">30</field>
    </record>
    <record id="rental_tile_customer_id_proofs" model="app.feature.app">
        <field name="feature_key">home.tile.customer_id_proofs</field>
        <field name="name">Customer ID Proofs Tile</field>
        <field name="description">Home tile: view customer identity documents.</field>
        <field name="sequence">31</field>
    </record>
    <record id="rental_tile_customer_ratings" model="app.feature.app">
        <field name="feature_key">home.tile.customer_ratings</field>
        <field name="name">Customer Ratings Tile</field>
        <field name="description">Home tile: view customer ratings.</field>
        <field name="sequence">32</field>
    </record>

    <!-- Reporting -->
    <record id="rental_tile_sales_report" model="app.feature.app">
        <field name="feature_key">home.tile.sales_report</field>
        <field name="name">Sales Report Tile</field>
        <field name="description">Home tile: view sales analytics and reports.</field>
        <field name="sequence">40</field>
    </record>
    <record id="rental_tile_expenses" model="app.feature.app">
        <field name="feature_key">home.tile.expenses</field>
        <field name="name">Expenses Tile</field>
        <field name="description">Home tile: record and track business expenses.</field>
        <field name="sequence">41</field>
    </record>
    <record id="rental_tile_discount_details" model="app.feature.app">
        <field name="feature_key">home.tile.discount_details</field>
        <field name="name">Discount Details Tile</field>
        <field name="description">Home tile: view discount details report.</field>
        <field name="sequence">42</field>
    </record>
    <record id="rental_tile_tax_details" model="app.feature.app">
        <field name="feature_key">home.tile.tax_details</field>
        <field name="name">Tax Details Tile</field>
        <field name="description">Home tile: view tax details report.</field>
        <field name="sequence">43</field>
    </record>
    <record id="rental_tile_order_reports" model="app.feature.app">
        <field name="feature_key">home.tile.order_reports</field>
        <field name="name">Order Reports Tile</field>
        <field name="description">Home tile: detailed order reports.</field>
        <field name="sequence">44</field>
    </record>
    <record id="rental_tile_rental_dashboard" model="app.feature.app">
        <field name="feature_key">home.tile.rental_dashboard</field>
        <field name="name">Rental Dashboard Tile</field>
        <field name="description">Home tile: calendar / dashboard overview of rentals.</field>
        <field name="sequence">45</field>
    </record>

    <!-- Administration -->
    <record id="rental_tile_banners" model="app.feature.app">
        <field name="feature_key">home.tile.banners</field>
        <field name="name">Banners Tile (Admin)</field>
        <field name="description">Home tile: configure promotional banners.</field>
        <field name="sequence">50</field>
    </record>

    <!-- ============================================================ -->
    <!-- CHILD GATES (per-button) — nested under their tile           -->
    <!-- ============================================================ -->

    <!-- Rental Orders / order form -->
    <record id="rental_feat_orders_add" model="app.feature.app">
        <field name="feature_key">rental_orders.add</field>
        <field name="name">Add Rental Order</field>
        <field name="description">Show the "+" New Rental Order button on the Rental Orders list.</field>
        <field name="parent_id" ref="rental_tile_rental_orders"/>
        <field name="sequence">110</field>
    </record>
    <record id="rental_feat_confirm" model="app.feature.app">
        <field name="feature_key">rental.confirm</field>
        <field name="name">Confirm Order</field>
        <field name="description">Show the Confirm Order button on the rental order form.</field>
        <field name="parent_id" ref="rental_tile_rental_orders"/>
        <field name="sequence">111</field>
    </record>
    <record id="rental_feat_checkout" model="app.feature.app">
        <field name="feature_key">rental.checkout</field>
        <field name="name">Checkout</field>
        <field name="description">Show the Checkout (open checkout wizard) button on the rental order form.</field>
        <field name="parent_id" ref="rental_tile_rental_orders"/>
        <field name="sequence">112</field>
    </record>
    <record id="rental_feat_checkin" model="app.feature.app">
        <field name="feature_key">rental.checkin</field>
        <field name="name">Check-In</field>
        <field name="description">Show the Check-In (open check-in wizard) button on the rental order form.</field>
        <field name="parent_id" ref="rental_tile_rental_orders"/>
        <field name="sequence">113</field>
    </record>
    <record id="rental_feat_mark_done" model="app.feature.app">
        <field name="feature_key">rental.mark_done</field>
        <field name="name">Mark Done</field>
        <field name="description">Show the Mark Order Done button on the rental order form.</field>
        <field name="parent_id" ref="rental_tile_rental_orders"/>
        <field name="sequence">114</field>
    </record>
    <record id="rental_feat_mark_paid" model="app.feature.app">
        <field name="feature_key">rental.mark_paid</field>
        <field name="name">Mark Paid</field>
        <field name="description">Show the Mark as Paid button on the rental order form.</field>
        <field name="parent_id" ref="rental_tile_rental_orders"/>
        <field name="sequence">115</field>
    </record>
    <record id="rental_feat_generate_invoice" model="app.feature.app">
        <field name="feature_key">rental.generate_invoice</field>
        <field name="name">Generate Invoice</field>
        <field name="description">Show the Generate Invoice button(s) on checkout / check-in.</field>
        <field name="parent_id" ref="rental_tile_rental_orders"/>
        <field name="sequence">116</field>
    </record>
    <record id="rental_feat_export_pdf" model="app.feature.app">
        <field name="feature_key">rental.export_pdf</field>
        <field name="name">Export Invoice PDF</field>
        <field name="description">Show the Generate / Download invoice PDF button on the rental order form.</field>
        <field name="parent_id" ref="rental_tile_rental_orders"/>
        <field name="sequence">117</field>
    </record>
    <record id="rental_feat_apply_tax" model="app.feature.app">
        <field name="feature_key">rental.apply_tax</field>
        <field name="name">Apply Tax</field>
        <field name="description">Show the Apply Tax control on the rental order form.</field>
        <field name="parent_id" ref="rental_tile_rental_orders"/>
        <field name="sequence">118</field>
    </record>
    <record id="rental_feat_apply_discount" model="app.feature.app">
        <field name="feature_key">rental.apply_discount</field>
        <field name="name">Apply Discount</field>
        <field name="description">Show the Apply Discount control on the rental order form.</field>
        <field name="parent_id" ref="rental_tile_rental_orders"/>
        <field name="sequence">119</field>
    </record>
    <record id="rental_feat_rate_customer" model="app.feature.app">
        <field name="feature_key">rental.rate_customer</field>
        <field name="name">Rate Customer</field>
        <field name="description">Show the Rate Customer button on the rental order form.</field>
        <field name="parent_id" ref="rental_tile_rental_orders"/>
        <field name="sequence">120</field>
    </record>

    <!-- Sales Report -->
    <record id="rental_feat_sr_export_pdf" model="app.feature.app">
        <field name="feature_key">sales_report.export_pdf</field>
        <field name="name">Sales Report - Full PDF</field>
        <field name="description">Show the Full PDF export button on the Sales Report screen.</field>
        <field name="parent_id" ref="rental_tile_sales_report"/>
        <field name="sequence">130</field>
    </record>
    <record id="rental_feat_sr_export_excel" model="app.feature.app">
        <field name="feature_key">sales_report.export_excel</field>
        <field name="name">Sales Report - Full Excel</field>
        <field name="description">Show the Full Excel export button on the Sales Report screen.</field>
        <field name="parent_id" ref="rental_tile_sales_report"/>
        <field name="sequence">131</field>
    </record>
    <record id="rental_feat_sr_customers_export" model="app.feature.app">
        <field name="feature_key">sales_report.customers_export</field>
        <field name="name">Sales Report - Customers Export</field>
        <field name="description">Show the PDF/Excel export buttons on the Customers Ranked section.</field>
        <field name="parent_id" ref="rental_tile_sales_report"/>
        <field name="sequence">132</field>
    </record>
    <record id="rental_feat_sr_tools_export" model="app.feature.app">
        <field name="feature_key">sales_report.tools_export</field>
        <field name="name">Sales Report - Tools Export</field>
        <field name="description">Show the PDF/Excel export buttons on the Tools Ranked section.</field>
        <field name="parent_id" ref="rental_tile_sales_report"/>
        <field name="sequence">133</field>
    </record>
    <record id="rental_feat_sr_date_filter" model="app.feature.app">
        <field name="feature_key">sales_report.date_filter</field>
        <field name="name">Sales Report - Custom Date Range</field>
        <field name="description">Show the custom date-range (calendar) controls on the Sales Report screen.</field>
        <field name="parent_id" ref="rental_tile_sales_report"/>
        <field name="sequence">134</field>
    </record>

    <!-- Tools -->
    <record id="rental_feat_tools_add" model="app.feature.app">
        <field name="feature_key">tools.add</field>
        <field name="name">Add Tool</field>
        <field name="description">Show the Add Tool button on the Tools screen.</field>
        <field name="parent_id" ref="rental_tile_tools"/>
        <field name="sequence">140</field>
    </record>
    <record id="rental_feat_tools_edit" model="app.feature.app">
        <field name="feature_key">tools.edit</field>
        <field name="name">Edit Tool</field>
        <field name="description">Allow opening a tool to edit it from the Tools screen.</field>
        <field name="parent_id" ref="rental_tile_tools"/>
        <field name="sequence">141</field>
    </record>
    <record id="rental_feat_tools_save" model="app.feature.app">
        <field name="feature_key">tools.save</field>
        <field name="name">Save Tool</field>
        <field name="description">Show the Save / Generate button on the Tool form.</field>
        <field name="parent_id" ref="rental_tile_tools"/>
        <field name="sequence">142</field>
    </record>

    <!-- Pricing -->
    <record id="rental_feat_pricing_save" model="app.feature.app">
        <field name="feature_key">pricing.save</field>
        <field name="name">Save Pricing Rule</field>
        <field name="description">Show the Save button on the Pricing Rule form.</field>
        <field name="parent_id" ref="rental_tile_pricing"/>
        <field name="sequence">150</field>
    </record>

    <!-- Tool Availability -->
    <record id="rental_feat_avail_export_pdf" model="app.feature.app">
        <field name="feature_key">tool_availability.export_pdf</field>
        <field name="name">Availability - Export PDF</field>
        <field name="description">Show the Download PDF button on the Tool Availability screen.</field>
        <field name="parent_id" ref="rental_tile_tool_availability"/>
        <field name="sequence">160</field>
    </record>
    <record id="rental_feat_avail_export_excel" model="app.feature.app">
        <field name="feature_key">tool_availability.export_excel</field>
        <field name="name">Availability - Export Excel</field>
        <field name="description">Show the Download Excel button on the Tool Availability screen.</field>
        <field name="parent_id" ref="rental_tile_tool_availability"/>
        <field name="sequence">161</field>
    </record>

    <!-- Customers -->
    <record id="rental_feat_customers_add" model="app.feature.app">
        <field name="feature_key">customers.add</field>
        <field name="name">Add Customer</field>
        <field name="description">Show the Add Customer button on the Customers screen.</field>
        <field name="parent_id" ref="rental_tile_customers"/>
        <field name="sequence">170</field>
    </record>
    <record id="rental_feat_customers_edit" model="app.feature.app">
        <field name="feature_key">customers.edit</field>
        <field name="name">Edit Customer</field>
        <field name="description">Show the Save button when editing a customer.</field>
        <field name="parent_id" ref="rental_tile_customers"/>
        <field name="sequence">171</field>
    </record>
    <record id="rental_feat_customers_delete" model="app.feature.app">
        <field name="feature_key">customers.delete</field>
        <field name="name">Delete Customer</field>
        <field name="description">Show the Delete Customer button on the customer edit modal.</field>
        <field name="parent_id" ref="rental_tile_customers"/>
        <field name="sequence">172</field>
    </record>

    <!-- Expenses -->
    <record id="rental_feat_expenses_create" model="app.feature.app">
        <field name="feature_key">expenses.create</field>
        <field name="name">Create Expense</field>
