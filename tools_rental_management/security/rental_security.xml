<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_rental" model="ir.module.category">
        <field name="name">Tools Rental</field>
        <field name="sequence">50</field>
    </record>

    <record id="res_groups_privilege_rental" model="res.groups.privilege">
        <field name="name">Tools Rental</field>
        <field name="category_id" ref="module_category_rental"/>
        <field name="sequence">50</field>
    </record>

    <record id="group_rental_user" model="res.groups">
        <field name="name">Rental User</field>
        <field name="privilege_id" ref="res_groups_privilege_rental"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_rental_manager" model="res.groups">
        <field name="name">Rental Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_rental"/>
        <field name="implied_ids" eval="[(4, ref('group_rental_user'))]"/>
    </record>
</odoo>
