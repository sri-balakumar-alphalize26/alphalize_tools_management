<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════
         PRICING RULES
         ═══════════════════════════════════════════════════ -->

    <!-- ── List View ──────────────────────────────────── -->
    <record id="view_rental_pricing_tree" model="ir.ui.view">
        <field name="name">rental.pricing.tree</field>
        <field name="model">rental.pricing</field>
        <field name="arch" type="xml">
            <list editable="bottom"
                  decoration-success="price > 0"
                  decoration-danger="price == 0"
                  decoration-muted="active == False">
                <field name="active" column_invisible="1"/>
                <field name="sequence" widget="handle"/>
                <field name="product_name" string="Product" readonly="1"/>
                <field name="serial_count" string="Units" readonly="1"
                       decoration-info="serial_count > 1"/>
                <field name="category_id" string="Category" optional="show"/>
                <field name="period_type" string="Period"
                       widget="badge"
                       decoration-info="period_type == 'day'"
                       decoration-success="period_type == 'week'"
                       decoration-warning="period_type == 'month'"
                       decoration-danger="period_type == 'fixed'"/>
                <field name="price" string="Price" widget="monetary"/>
                <field name="late_fee_per_day" string="Late Fee / Day" widget="monetary"/>
                <field name="min_duration" string="Min Dur." optional="hide"/>
                <field name="max_duration" string="Max Dur." optional="hide"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="is_primary_pricing" column_invisible="1"/>
                <field name="tool_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ── Form View ──────────────────────────────────── -->
    <record id="view_rental_pricing_form" model="ir.ui.view">
        <field name="name">rental.pricing.form</field>
        <field name="model">rental.pricing</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title mb-3">
                        <h1>
                            <field name="product_name" readonly="1"
                                   placeholder="Product Name"/>
                        </h1>
                        <h3 class="text-muted" invisible="not category_id">
                            <i class="fa fa-tag me-1"/>
                            <field name="category_id" readonly="1"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Pricing">
                            <field name="period_type" widget="radio"/>
                            <field name="price" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="late_fee_per_day" widget="monetary"/>
                        </group>
                        <group string="Duration Range">
                            <field name="min_duration"/>
                            <field name="max_duration"/>
                            <field name="active" widget="boolean_toggle"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Internal">
                        <group>
                            <field name="tool_id" readonly="1"/>
                            <field name="serial_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="is_primary_pricing" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes" placeholder="Any notes about this pricing rule..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search View ────────────────────────────────── -->
    <record id="view_rental_pricing_search" model="ir.ui.view">
        <field name="name">rental.pricing.search</field>
        <field name="model">rental.pricing</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_name"/>
                <field name="category_id"/>
                <field name="period_type"/>
                <separator/>
                <filter name="show_all_serials" string="Show All Serials"
                        domain="[('is_primary_pricing', 'in', [True, False])]"/>
                <filter name="filter_has_price" string="Priced"
                        domain="[('price', '>', 0)]"/>
                <filter name="filter_no_price" string="No Price"
                        domain="[('price', '=', 0)]"/>
                <filter name="filter_has_late_fee" string="Has Late Fee"
                        domain="[('late_fee_per_day', '>', 0)]"/>
                <separator/>
                <group>
                    <filter name="group_category" string="Category"
                            context="{'group_by': 'category_id'}"/>
                    <filter name="group_period" string="Period Type"
                            context="{'group_by': 'period_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action: delete old act_window, create client action ── -->
    <delete model="ir.actions.act_window"
            search="[('xml_id', '=', 'tools_rental_management.action_rental_pricing')]"/>

    <record id="action_rental_pricing_dashboard" model="ir.actions.client">
        <field name="name">Pricing Rules</field>
        <field name="tag">rental_pricing_dashboard</field>
    </record>


    <!-- ═══════════════════════════════════════════════════
         PRICING TEMPLATES
         ═══════════════════════════════════════════════════ -->

    <!-- ── List View ──────────────────────────────────── -->
    <record id="view_rental_pricing_template_tree" model="ir.ui.view">
        <field name="name">rental.pricing.template.tree</field>
        <field name="model">rental.pricing.template</field>
        <field name="arch" type="xml">
            <list decoration-muted="active == False">
                <field name="name" string="Template Name"/>
                <field name="line_count" string="Pricing Lines"
                       decoration-info="line_count > 0"
                       decoration-danger="line_count == 0"/>
                <field name="description"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ── Form View ──────────────────────────────────── -->
    <record id="view_rental_pricing_template_form" model="ir.ui.view">
        <field name="name">rental.pricing.template.form</field>
        <field name="model">rental.pricing.template</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_apply_to_tools" type="object"
                            string="Apply to Tools" class="btn-primary"
                            icon="fa-magic"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-list-ol" disabled="1">
                            <field name="line_count" widget="statinfo"
                                   string="Pricing Lines"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Template Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="description"
                                   placeholder="Describe this pricing template..."/>
                        </group>
                    </group>
                    <separator string="Pricing Lines"/>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="period_type" string="Period"
                                   widget="badge"
                                   decoration-info="period_type == 'day'"
                                   decoration-success="period_type == 'week'"
                                   decoration-warning="period_type == 'month'"
                                   decoration-danger="period_type == 'fixed'"/>
                            <field name="price" string="Price" widget="monetary"/>
                            <field name="late_fee_per_day" string="Late Fee / Day"
                                   widget="monetary"/>
                            <field name="min_duration" string="Min Dur."
                                   optional="show"/>
                            <field name="max_duration" string="Max Dur."
                                   optional="show"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────── -->
    <record id="action_rental_pricing_template" model="ir.actions.act_window">
        <field name="name">Pricing Templates</field>
        <field name="res_model">rental.pricing.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
