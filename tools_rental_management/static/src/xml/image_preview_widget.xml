<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="tools_rental_management.ImagePreviewField">
        <div class="o_field_image_preview d-inline-block">
            <!-- Fixed-size thumbnail (same size for every image) -->
            <t t-if="hasImage">
                <img t-att-src="imageUrl"
                     style="width: 120px; height: 120px; cursor: pointer;
                            border: 1px solid #dee2e6; border-radius: 4px;
                            padding: 2px; object-fit: cover; background: #fff;"
                     t-on-click="onImageClick"
                     title="Click to view full size"/>
            </t>
            <t t-else="">
                <span class="text-muted fst-italic">No image</span>
            </t>

            <!-- Full-screen popup overlay (white bg for signatures, dark for photos) -->
            <div t-if="state.showModal"
                 class="o_image_preview_modal"
                 t-att-style="overlayStyle"
                 t-on-click="onOverlayClick">
                <!-- Close button -->
                <button class="btn"
                        t-attf-style="position:absolute;top:15px;right:25px;
                               z-index:10001;font-size:36px;line-height:1;
                               opacity:0.85;background:none;border:none;
                               color:{{closeBtnColor}};"
                        t-on-click="onCloseModal"
                        title="Close">
                    &#215;
                </button>
                <!-- Full-size image (original size, no forced dimensions) -->
                <img t-att-src="imageUrl"
                     style="max-width: 90vw; max-height: 90vh; object-fit: contain;
                            border-radius: 6px;
                            box-shadow: 0 4px 40px rgba(0,0,0,0.3);"/>
            </div>
        </div>
    </t>
</templates>
