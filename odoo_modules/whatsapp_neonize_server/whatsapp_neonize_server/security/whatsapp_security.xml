<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Module Category -->
    <record id="module_category_whatsapp" model="ir.module.category">
        <field name="name">WhatsApp</field>
        <field name="sequence">100</field>
    </record>

    <!-- Privilege (Odoo 19: connects ir.module.category to res.groups) -->
    <record id="privilege_whatsapp" model="res.groups.privilege">
        <field name="name">WhatsApp</field>
        <field name="sequence">10</field>
        <field name="category_id" ref="module_category_whatsapp"/>
    </record>

    <!-- User Group -->
    <record id="group_whatsapp_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_whatsapp"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Manager Group -->
    <record id="group_whatsapp_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_whatsapp"/>
        <field name="implied_ids" eval="[(4, ref('group_whatsapp_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
