<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rental_checkout_wizard_form" model="ir.ui.view">
        <field name="name">rental.checkout.wizard.form</field>
        <field name="model">rental.checkout.wizard</field>
        <field name="arch" type="xml">
            <form string="Check-Out Tools">
                <group>
                    <group>
                        <field name="order_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="checkout_date"/>
                    </group>
                </group>
                <separator string="Tools"/>
                <field name="line_ids">
                    <list editable="bottom" no_open="1">
                        <field name="order_line_id" column_invisible="1" force_save="1"/>
                        <field name="tool_id" column_invisible="1" force_save="1"/>
                        <field name="product_id" column_invisible="1" force_save="1"/>
                        <field name="tool_name" string="Tool" readonly="1"/>
                        <field name="serial_number" string="Serial No." readonly="1"/>
                        <field name="unit_price" string="Price" readonly="1" force_save="1"/>
                        <field name="planned_duration" string="Duration" readonly="1" force_save="1"/>
                        <field name="rental_cost" string="Total" readonly="1" force_save="1"/>
                        <field name="condition" string="Condition" required="1"/>
                        <field name="tool_image" string="Tool Photo"
                               widget="image" options='{"size": [80, 80]}'/>
                        <field name="currency_id" column_invisible="1"/>
                    </list>
                </field>
                <separator string="Advance Payment (Optional)"/>
                <group>
                    <group>
                        <field name="advance_amount" string="Advance Amount"/>
                        <field name="payment_method" string="Payment Method"
                               invisible="advance_amount == 0"
                               required="advance_amount > 0"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group/>
                </group>
                <group invisible="payment_method != 'cash' or advance_amount == 0">
                    <group>
                        <field name="cash_received" string="Cash Received"/>
                    </group>
                    <group>
                        <field name="cash_balance" readonly="1"
                               string="Balance to Return"/>
                    </group>
                </group>
                <separator string="ID Proof - Front Side (Required)"/>
                <group>
                    <field name="id_proof_front" widget="camera_file_upload"
                           nolabel="1" colspan="2"/>
                </group>
                <separator string="ID Proof - Back Side (Optional)"/>
                <group>
                    <field name="id_proof_back" widget="camera_file_upload"
                           nolabel="1" colspan="2"/>
                </group>
                <separator string="Customer Signature (Required)"/>
                <group>
                    <field name="customer_signature" widget="signature" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_confirm_checkout" type="object"
                            string="✓ Confirm Check-Out" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
