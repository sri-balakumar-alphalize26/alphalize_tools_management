<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_checkin_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center" style="color: #2c3e50;">CHECK-IN INVOICE</h2>
                        <h4 class="text-center text-muted">
                            <span t-field="doc.name"/>
                        </h4>
                        <br/>

                        <!-- Parties -->
                        <div class="row">
                            <div class="col-6">
                                <strong>Rental Company:</strong><br/>
                                <span t-field="doc.company_id.partner_id.name"/><br/>
                                <t t-if="doc.company_id.partner_id.street">
                                    <span t-field="doc.company_id.partner_id.street"/><br/>
                                </t>
                                <t t-if="doc.company_id.partner_id.city">
                                    <span t-field="doc.company_id.partner_id.city"/>
                                </t>
                                <t t-if="doc.company_id.partner_id.zip">
                                    <span t-field="doc.company_id.partner_id.zip"/>
                                </t>
                                <br/>
                                <t t-if="doc.company_id.phone">
                                    Phone: <span t-field="doc.company_id.phone"/>
                                </t>
                            </div>
                            <div class="col-6">
                                <strong>Customer:</strong><br/>
                                <span t-field="doc.partner_id.name"/><br/>
                                <t t-if="doc.partner_id.street">
                                    <span t-field="doc.partner_id.street"/><br/>
                                </t>
                                <t t-if="doc.partner_id.city">
                                    <span t-field="doc.partner_id.city"/>
                                </t>
                                <t t-if="doc.partner_id.zip">
                                    <span t-field="doc.partner_id.zip"/>
                                </t>
                                <br/>
                                <t t-if="doc.partner_phone">
                                    Phone: <span t-field="doc.partner_phone"/>
                                </t>
                                <t t-if="doc.partner_email">
                                    <br/>Email: <span t-field="doc.partner_email"/>
                                </t>
                            </div>
                        </div>
                        <br/>

                        <!-- Customer ID -->
                        <t t-if="doc.customer_code">
                            <div style="text-align: center; margin-bottom: 12px;">
                                <span style="background-color: #714B67; color: #fff; padding: 6px 18px; border-radius: 4px; font-size: 14px; font-weight: 700; letter-spacing: 1px;">
                                    Customer ID: <t t-out="doc.customer_code"/>
                                </span>
                            </div>
                        </t>

                        <!-- Rental Details -->
                        <table class="table table-sm">
                            <tr>
                                <td><strong>Order Date:</strong></td>
                                <td><span t-field="doc.date_order" t-options='{"widget": "date"}'/></td>
                                <td><strong>Check-Out Date:</strong></td>
                                <td><span t-field="doc.date_checkout" t-options='{"widget": "date"}'/></td>
                            </tr>
                            <tr>
                                <td><strong>Check-In Date:</strong></td>
                                <td><span t-field="doc.date_checkin" t-options='{"widget": "date"}'/></td>
                                <td><strong>Billing Period:</strong></td>
                                <td><span t-field="doc.rental_period_type"/></td>
                            </tr>
                            <tr>
                                <td><strong>Planned Duration:</strong></td>
                                <td><span t-esc="int(doc.rental_duration)"/> Days</td>
                                <td><strong>Actual Duration:</strong></td>
                                <td><span t-field="doc.actual_duration_display"/></td>
                            </tr>
                            <tr>
                                <td><strong>Responsible:</strong></td>
                                <td><span t-field="doc.user_id.name"/></td>
                                <td></td>
                                <td></td>
                            </tr>
                        </table>

                        <!-- Late Return Warning -->
                        <t t-if="doc.is_late">
                            <div style="background-color: #fff3cd; border: 1px solid #ffc107; padding: 8px 12px; margin-bottom: 10px; border-radius: 4px;">
                                <strong style="color: #856404;">LATE RETURN</strong>
                                <span style="color: #856404;"> — This rental exceeded the planned return date.</span>
                            </div>
                        </t>

                        <!-- Tools Table -->
                        <h5 style="margin-top: 15px;">Tools / Equipment</h5>
                        <table class="table table-bordered table-sm" style="font-size: 11px;">
                            <thead style="background-color: #e9ecef; color: #333;">
                                <tr>
                                    <th>#</th>
                                    <th>Tool</th>
                                    <th>Serial No.</th>
                                    <th>Out Condition</th>
                                    <th>In Condition</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end">Duration</th>
                                    <th class="text-end">Extra Days</th>
                                    <th class="text-end">Late Fee/Day</th>
                                    <th class="text-end">Late Fee</th>
                                    <th>Damage Note</th>
                                    <th class="text-end">Damage Charge</th>
                                    <th class="text-end">Discount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="idx" t-value="0"/>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <t t-set="idx" t-value="idx + 1"/>
                                    <td><t t-out="idx"/></td>
                                    <td>
                                        <t t-if="line.product_id">
                                            <span t-field="line.product_id.name"/>
                                        </t>
                                        <t t-elif="line.tool_id">
                                            <span t-field="line.tool_id.name"/>
                                        </t>
                                    </td>
                                    <td><span t-esc="line.tool_id.serial_number or ''"/></td>
                                    <td>
                                        <t t-if="line.checkout_condition">
                                            <span t-field="line.checkout_condition"/>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-if="line.checkin_condition">
                                            <span t-field="line.checkin_condition"/>
                                        </t>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.unit_price"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="int(line.planned_duration)"/>
                                    </td>
                                    <!-- Extra Days -->
                                    <td class="text-end"
                                        t-att-style="'color: red; font-weight: bold;' if line.extra_days else ''">
                                        <span t-esc="line.extra_days"/>
                                    </td>
                                    <!-- Late Fee/Day — get from pricing or tool -->
                                    <td class="text-end"
                                        t-att-style="'color: red; font-weight: bold;' if line.late_fee_amount else ''">
                                        <t t-if="line.pricing_id and line.pricing_id.late_fee_per_day">
                                            <span t-field="line.pricing_id.late_fee_per_day"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </t>
                                        <t t-elif="line.tool_id and line.tool_id.late_fee_per_day">
                                            <span t-field="line.tool_id.late_fee_per_day"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </t>
                                        <t t-else="">
                                            <span t-esc="'%s 0.00' % doc.currency_id.symbol"/>
                                        </t>
                                    </td>
                                    <!-- Late Fee — highlighted red when > 0 -->
                                    <td class="text-end"
                                        t-att-style="'color: red; font-weight: bold;' if line.late_fee_amount else ''">
                                        <span t-field="line.late_fee_amount"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <td><span t-esc="line.damage_note or ''"/></td>
                                    <!-- Damage Charge — highlighted red when > 0 -->
                                    <td class="text-end"
                                        t-att-style="'color: red; font-weight: bold;' if line.damage_charge else ''">
                                        <span t-field="line.damage_charge"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                    <!-- Discount — show type + calculated amount -->
                                    <td class="text-end"
                                        t-att-style="'color: green; font-weight: bold;' if line.discount_line_amount else ''">
                                        <t t-if="line.discount_type == 'percentage' and line.discount_value">
                                            <span t-esc="str(int(line.discount_value)) + '%'"/>
                                            (<span t-field="line.discount_line_amount"
                                                   t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>)
                                        </t>
                                        <t t-elif="line.discount_type == 'fixed' and line.discount_value">
                                            <span t-field="line.discount_line_amount"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </t>
                                        <t t-elif="line.discount_line_amount">
                                            <span t-field="line.discount_line_amount"
                                                  t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                        </t>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Totals -->
                        <div class="row">
                            <div class="col-6"/>
                            <div class="col-6">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Subtotal:</strong></td>
                                        <td class="text-end"><span t-field="doc.subtotal"/></td>
                                    </tr>
                                    <t t-if="doc.late_fee">
                                        <tr style="color: red; font-weight: bold;">
                                            <td>Late Fees:</td>
                                            <td class="text-end"><span t-field="doc.late_fee"/></td>
                                        </tr>
                                    </t>
                                    <t t-if="doc.damage_charges">
                                        <tr style="color: red; font-weight: bold;">
                                            <td>Damage Charges:</td>
                                            <td class="text-end"><span t-field="doc.damage_charges"/></td>
                                        </tr>
                                    </t>
                                    <t t-if="doc.discount_amount">
                                        <tr style="color: green; font-weight: bold;">
                                            <td>Discount:</td>
                                            <td class="text-end">-<span t-field="doc.discount_amount"/></td>
                                        </tr>
                                    </t>
                                    <tr style="border-top: 2px solid #000;">
                                        <td><strong style="font-size: 14px;">TOTAL:</strong></td>
                                        <td class="text-end">
                                            <strong style="font-size: 14px;">
                                                <span t-field="doc.total_amount"/>
                                            </strong>
                                        </td>
                                    </tr>
                                    <t t-if="doc.advance_amount and not doc.advance_returned">
                                        <tr style="color: #007bff;">
                                            <td>Advance Paid (-):</td>
                                            <td class="text-end">
                                                -<span t-field="doc.advance_amount"/>
                                            </td>
                                        </tr>
                                        <tr style="border-top: 2px solid #000;">
                                            <td>
                                                <strong style="font-size: 15px; color: #2c3e50;">
                                                    AMOUNT DUE:
                                                </strong>
                                            </td>
                                            <td class="text-end">
                                                <strong style="font-size: 15px; color: #2c3e50;">
                                                    <span t-field="doc.amount_due"/>
                                                </strong>
                                            </td>
                                        </tr>
                                    </t>
                                    <t t-if="doc.advance_amount and doc.advance_returned">
                                        <tr>
                                            <td><em>Advance Returned:</em></td>
                                            <td class="text-end">
                                                <span t-field="doc.advance_amount"/>
                                            </td>
                                        </tr>
                                    </t>
                                </table>
                            </div>
                        </div>

                        <!-- Advance Details -->
                        <t t-if="doc.advance_amount">
                            <div class="row" style="margin-top: 10px;">
                                <div class="col-6">
                                    <table class="table table-sm" style="font-size: 12px;">
                                        <tr>
                                            <td><strong>Advance:</strong></td>
                                            <td><span t-field="doc.advance_amount"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Returned:</strong></td>
                                            <td>
                                                <t t-if="doc.advance_returned">Yes</t>
                                                <t t-else="">No</t>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </t>

                        <!-- Terms -->
                        <t t-if="doc.terms">
                            <br/>
                            <h5>Terms &amp; Conditions</h5>
                            <div t-field="doc.terms"/>
                        </t>

                        <!-- Signatures -->
                        <div class="row" style="margin-top: 40px;">
                            <!-- Customer Signature -->
                            <div t-att-class="'col-4 text-center' if doc.discount_auth_signature else 'col-5 text-center'">
                                <t t-if="doc.checkin_customer_signature">
                                    <img t-att-src="image_data_uri(doc.checkin_customer_signature)"
                                         style="max-height: 80px; max-width: 100%;"/>
                                    <br/>
                                </t>
                                <t t-else="">
                                    <hr/>
                                </t>
                                <strong>Customer</strong><br/>
                                <span t-field="doc.partner_id.name"/>
                                <t t-if="doc.checkin_customer_signature_date">
                                    <br/>
                                    <small style="color: #666;">
                                        <span t-field="doc.checkin_customer_signature_date"
                                              t-options='{"widget": "datetime", "format": "dd/MM/yyyy, HH:mm"}'/>
                                    </small>
                                </t>
                            </div>
                            <!-- Authority Signature -->
                            <div t-att-class="'col-4 text-center' if doc.discount_auth_signature else 'col-5 text-center'" t-attf-style="#{'margin-left: auto;' if not doc.discount_auth_signature else ''}">
                                <t t-if="doc.checkin_signature">
                                    <img t-att-src="image_data_uri(doc.checkin_signature)"
                                         style="max-height: 80px; max-width: 100%;"/>
                                    <br/>
                                </t>
                                <t t-else="">
                                    <hr/>
                                </t>
                                <strong>Authority</strong><br/>
                                <t t-if="doc.checkin_signer_name">
                                    <span t-field="doc.checkin_signer_name"/>
                                </t>
                                <t t-else="">
                                    <span t-field="doc.user_id.name"/>
                                </t>
                                <t t-if="doc.checkin_signature_date">
                                    <br/>
                                    <small style="color: #666;">
                                        <span t-field="doc.checkin_signature_date"
                                              t-options='{"widget": "datetime", "format": "dd/MM/yyyy, HH:mm"}'/>
                                    </small>
                                </t>
                            </div>
                            <!-- Discount Authorization Signature (only if discount exists) -->
                            <t t-if="doc.discount_auth_signature">
                                <div class="col-4 text-center">
                                    <img t-att-src="image_data_uri(doc.discount_auth_signature)"
                                         style="max-height: 80px; max-width: 100%;"/>
                                    <br/>
                                    <strong>Discount Auth.</strong><br/>
                                    <t t-if="doc.discount_authorized_by">
                                        <span t-field="doc.discount_authorized_by"/>
                                    </t>
                                    <t t-if="doc.discount_applied_date">
                                        <br/>
                                        <small style="color: #666;">
                                            <span t-field="doc.discount_applied_date"
                                                  t-options='{"widget": "datetime", "format": "dd/MM/yyyy, HH:mm"}'/>
                                        </small>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
