    </record>

    <!-- Banners -->
    <record id="rental_feat_banners_add" model="app.feature.app">
        <field name="feature_key">banners.add</field>
        <field name="name">Add Banner</field>
        <field name="description">Show the New Banner button on the Banners screen.</field>
        <field name="parent_id" ref="rental_tile_banners"/>
        <field name="sequence">190</field>
    </record>
    <record id="rental_feat_banners_edit" model="app.feature.app">
        <field name="feature_key">banners.edit</field>
        <field name="name">Edit Banner</field>
        <field name="description">Show the Save button when editing a banner.</field>
        <field name="parent_id" ref="rental_tile_banners"/>
        <field name="sequence">191</field>
    </record>
    <record id="rental_feat_banners_delete" model="app.feature.app">
        <field name="feature_key">banners.delete</field>
        <field name="name">Delete Banner</field>
        <field name="description">Show the Delete button on the Banner detail screen.</field>
        <field name="parent_id" ref="rental_tile_banners"/>
        <field name="sequence">192</field>
    </record>

    </data>
</odoo>
