<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="tools_rental_management.RentalCategoryDashboard">
        <div class="rtr_dashboard o_action">

            <!-- ── Header ────────────────────────────────── -->
            <div class="rtr_header">
                <h2><i class="fa fa-tags me-2"/>Tool Categories</h2>
            </div>

            <!-- ── Scrollable content area ───────────────── -->
            <div class="rtr_scroll_area">

                <!-- ── Summary Cards ─────────────────────── -->
                <div class="rtr_cards">
                    <div class="rtr_card rtr_card_purple">
                        <div class="rtr_card_value" t-esc="state.totalCategories"/>
                        <div class="rtr_card_label">Categories</div>
                    </div>
                    <div class="rtr_card rtr_card_green">
                        <div class="rtr_card_value" t-esc="state.withTools"/>
                        <div class="rtr_card_label">With Tools</div>
                    </div>
                    <div class="rtr_card rtr_card_red">
                        <div class="rtr_card_value" t-esc="state.emptyCategories"/>
                        <div class="rtr_card_label">Empty</div>
                    </div>
                    <div class="rtr_card rtr_card_blue">
                        <div class="rtr_card_value" t-esc="state.totalSubCategories"/>
                        <div class="rtr_card_label">Sub Categories</div>
                    </div>
                    <div class="rtr_card rtr_card_orange">
                        <div class="rtr_card_value" t-esc="state.totalTools"/>
                        <div class="rtr_card_label">Total Tools</div>
                    </div>
                </div>

                <!-- ── Filter Bar ────────────────────────── -->
                <div class="rtr_filter_bar">
                    <div class="rtr_filter_item">
                        <i class="fa fa-search rtr_search_icon"/>
                        <input type="text" class="rtr_search_input"
                               placeholder="Search categories..."
                               t-on-input="onSearchInput"
                               t-att-value="state.searchQuery"/>
                    </div>
                    <div class="rtr_filter_item">
                        <label>Filter:</label>
                        <select class="rtr_select" t-on-change="onFilterType">
                            <option value="all">All Categories</option>
                            <option value="with_tools">With Tools</option>
                            <option value="empty">Empty Categories</option>
                            <option value="parent">Top-Level Only</option>
                            <option value="sub">Sub Categories Only</option>
                            <option value="archived">Archived</option>
                        </select>
                    </div>
                    <div class="rtr_filter_count">
                        Showing <strong t-esc="state.records.length"/> categories
                    </div>
                </div>

                <!-- ── Data Table ────────────────────────── -->
                <div class="rtr_table_wrap">
                    <table class="rtr_table">
                        <thead>
                            <tr>
                                <th class="rtr_th_num">#</th>
                                <th class="rtr_th_sortable rtr_th_name"
                                    t-on-click="() => this.onSort('name')">
                                    Category Name
                                    <i t-attf-class="fa {{ getSortIcon('name') }} rtr_sort_icon"/>
                                </th>
                                <th class="rtr_th_sortable rtr_th_center"
                                    t-on-click="() => this.onSort('code')">
                                    Code
                                    <i t-attf-class="fa {{ getSortIcon('code') }} rtr_sort_icon"/>
                                </th>
                                <th class="rtr_th_sortable"
                                    t-on-click="() => this.onSort('parent_id')">
                                    Parent
                                    <i t-attf-class="fa {{ getSortIcon('parent_id') }} rtr_sort_icon"/>
                                </th>
                                <th class="rtr_th_sortable rtr_th_center"
                                    t-on-click="() => this.onSort('tool_count')">
                                    Tools
                                    <i t-attf-class="fa {{ getSortIcon('tool_count') }} rtr_sort_icon"/>
                                </th>
                                <th class="rtr_th_sortable rtr_th_center"
                                    t-on-click="() => this.onSort('child_count')">
                                    Sub Categories
                                    <i t-attf-class="fa {{ getSortIcon('child_count') }} rtr_sort_icon"/>
                                </th>
                                <th class="rtr_th_center">Status</th>
                                <th class="rtr_th_center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.records" t-as="rec" t-key="rec.id">
                                <tr style="cursor:pointer" t-on-click="() => this.onOpenCategory(rec)">
                                    <td class="rtr_td_num">
                                        <t t-esc="rec_index + 1"/>
                                    </td>
                                    <td class="rtr_td_name">
                                        <i class="fa fa-tag me-1" style="color:#714B67"/>
                                        <t t-esc="rec.name"/>
                                    </td>
                                    <td class="rtr_td_center">
                                        <t t-if="rec.code">
                                            <span class="rtr_badge" style="background:#714B67">
                                                <t t-esc="rec.code"/>
                                            </span>
                                        </t>
                                        <t t-else="">
                                            <span style="color:#ccc">-</span>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-if="rec.parent_id">
                                            <i class="fa fa-folder-open-o me-1" style="color:#888"/>
                                            <t t-esc="rec.parent_id[1]"/>
                                        </t>
                                        <t t-else="">
                                            <span style="color:#ccc">-</span>
                                        </t>
                                    </td>
                                    <td class="rtr_td_center">
                                        <span t-attf-class="rtr_badge {{ rec.tool_count > 0 ? 'rtr_badge_success' : 'rtr_badge_muted' }}">
                                            <t t-esc="rec.tool_count"/>
                                        </span>
                                    </td>
                                    <td class="rtr_td_center">
                                        <t t-if="rec.child_count > 0">
                                            <span class="rtr_badge rtr_badge_info">
                                                <t t-esc="rec.child_count"/>
                                            </span>
                                        </t>
                                        <t t-else="">
                                            <span style="color:#ccc">0</span>
                                        </t>
                                    </td>
                                    <td class="rtr_td_center">
                                        <t t-if="rec.active">
                                            <span class="rtr_badge rtr_badge_success">Active</span>
                                        </t>
                                        <t t-else="">
                                            <span class="rtr_badge rtr_badge_danger">Archived</span>
                                        </t>
                                    </td>
                                    <td class="rtr_td_center">
                                        <t t-if="rec.tool_count > 0">
                                            <button class="btn btn-sm btn-outline-primary"
                                                    t-on-click="(ev) => this.onViewTools(rec, ev)"
                                                    title="View Tools">
                                                <i class="fa fa-wrench me-1"/>View
                                            </button>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                            <t t-if="!state.records.length">
                                <tr>
                                    <td colspan="8" class="rtr_no_data">
                                        No categories match your filters
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot t-if="state.records.length">
                            <tr class="rtr_total_row">
                                <td colspan="4" class="rtr_td_right">
                                    <strong>TOTAL</strong>
                                </td>
                                <td class="rtr_td_center">
                                    <strong t-esc="state.records.reduce((s, r) => s + (r.tool_count || 0), 0)"/>
                                </td>
                                <td class="rtr_td_center">
                                    <strong t-esc="state.records.reduce((s, r) => s + (r.child_count || 0), 0)"/>
                                </td>
                                <td colspan="2"/>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </t>
</templates>
