<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rental_checkin_wizard_form" model="ir.ui.view">
        <field name="name">rental.checkin.wizard.form</field>
        <field name="model">rental.checkin.wizard</field>
        <field name="arch" type="xml">
            <form string="Check-In Tools">
                <field name="is_partial" invisible="1"/>
                <field name="advance_amount" invisible="1"/>
                <group>
                    <group>
                        <field name="order_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="checkout_date" readonly="1"/>
                        <field name="checkin_date"/>
                        <field name="total_days_display" readonly="1" string="Duration"/>
                        <field name="total_days" invisible="1"/>
                        <field name="is_late" invisible="1"/>
                        <field name="return_advance"
                               invisible="advance_amount == 0"/>
                    </group>
                </group>
                <!-- Late Return Warning -->
                <div class="alert alert-warning" role="alert"
                     invisible="not is_late"
                     style="margin-bottom: 10px;">
                    <strong>Late Return</strong> — Customer has exceeded the planned rental duration. Late fees will apply.
                </div>
                <separator string="Tools"/>
                <field name="line_ids">
                    <list editable="bottom">
                        <field name="order_line_id" column_invisible="1"/>
                        <field name="tool_id" column_invisible="1"/>
                        <field name="product_id" column_invisible="1"/>
                        <field name="tool_name" string="Tool" readonly="1"/>
                        <field name="serial_number" string="Serial No." readonly="1"/>
                        <field name="condition" string="Condition" required="1"/>
                        <field name="quantity" column_invisible="1"/>
                        <field name="returned_so_far" column_invisible="1"/>
                        <field name="pending_qty" column_invisible="1"/>
                        <field name="return_qty" column_invisible="1"/>
                        <field name="duration_display" string="Duration" readonly="1"/>
                        <field name="extra_days" string="Extra Days" readonly="1"
                               decoration-danger="extra_days > 0"/>
                        <field name="late_fee_per_day" string="Late Fee/Day" readonly="1"/>
                        <field name="late_fee" string="Late Fee" readonly="1"
                               decoration-danger="late_fee > 0"/>
                        <field name="tool_image" widget="image"
                               options="{'size': [80, 60]}" optional="show"
                               string="Tool Photo"/>
                        <field name="damage_note"/>
                        <field name="damage_charge"/>
                        <field name="discount_display" string="Discount"
                               readonly="1"
                               decoration-success="discount_line_amount > 0"/>
                        <field name="discount_line_amount" string="Disc. Amt"
                               readonly="1"
                               decoration-success="discount_line_amount > 0"/>
                        <field name="tax_percentage" string="Tax %" readonly="1"/>
                        <field name="tax_amount" string="Tax Amt" readonly="1"/>
                        <field name="planned_days" column_invisible="1"/>
                        <field name="currency_id" column_invisible="1"/>
                    </list>
                </field>
                <separator string="Payment Summary"/>
                <group>
                    <group>
                        <field name="currency_id" invisible="1"/>
                        <field name="order_id" invisible="1"/>
                        <div invisible="advance_amount == 0">
                            <field name="advance_amount" readonly="1"
                                   string="Advance Collected at Checkout"/>
                            <field name="return_advance" string="Return Advance to Customer?"/>
                            <div invisible="not return_advance" class="text-muted">
                                <em>Advance will be returned to the customer.</em>
                            </div>
                        </div>
                    </group>
                    <group>
                        <field name="rental_subtotal" readonly="1"
                               string="Rental Subtotal"/>
                        <field name="tax_total" readonly="1"
                               invisible="tax_total == 0"
                               string="Tax"/>
                        <field name="total_late_fee" readonly="1"
                               string="Late Fees"
                               decoration-danger="total_late_fee > 0"/>
                        <field name="total_damage_charge" readonly="1"
                               string="Damage Charges"
                               decoration-danger="total_damage_charge > 0"/>
                        <field name="total_discount" readonly="1"
                               invisible="total_discount == 0"
                               string="Discount"
                               decoration-success="total_discount > 0"/>
                        <field name="total_bill" readonly="1"
                               string="TOTAL"
                               class="oe_subtotal_footer_separator"/>
                        <field name="advance_amount" readonly="1"
                               invisible="advance_amount == 0 or return_advance"
                               string="Advance Paid (-)"
                               decoration-info="advance_amount > 0"/>
                        <field name="advance_amount" readonly="1"
                               invisible="advance_amount == 0 or not return_advance"
                               string="Advance (Returned)"
                               decoration-muted="1"/>
                        <field name="balance_due"
                               string="AMOUNT DUE"
                               class="oe_subtotal_footer_separator"
                               decoration-danger="balance_due > 0"
                               force_save="1"/>
                    </group>
                </group>
                <div invisible="is_partial">
                    <separator string="Payment Method"/>
                    <group>
                        <group>
                            <field name="is_partial" invisible="1"/>
                            <field name="checkin_payment_method" string="Payment Method"
                                   required="not is_partial"/>
                        </group>
                        <group/>
                    </group>
                    <group invisible="checkin_payment_method != 'cash'">
                        <group>
                            <field name="checkin_cash_received" string="Cash Received"/>
                        </group>
                        <group>
                            <field name="checkin_cash_balance"
                                   string="Balance to Return"
                                   force_save="1"/>
                        </group>
                    </group>
                </div>
                <separator string="Customer Signature (Required)"/>
                <group>
                    <field name="checkin_customer_signature" widget="signature"
                           nolabel="1" string="Customer Signature"/>
                </group>
                <separator string="Authority Signature (Required)"/>
                <group>
                    <field name="customer_name" placeholder="Signer name..."
                           required="1" string="Signer Name"/>
                </group>
                <group>
                    <field name="customer_signature" widget="signature" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_save_partial" type="object"
                            string="Save (Partial Return)" class="btn-warning"
                            invisible="not is_partial"/>
                    <button name="action_confirm_checkin" type="object"
                            string="Confirm Check-In" class="btn-primary"
                            invisible="is_partial"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Rating-only view (re-uses the same rental.checkin.wizard record) -->
    <record id="view_rental_checkin_wizard_rating_form" model="ir.ui.view">
        <field name="name">rental.checkin.wizard.rating.form</field>
        <field name="model">rental.checkin.wizard</field>
        <field name="arch" type="xml">
            <form string="Customer Rating">
                <sheet>
                    <div class="oe_title">
                        <h2 style="text-align:center;">How was the customer's behavior?</h2>
                        <p class="text-muted text-center">
                            Rate how this customer returned the tools. The rating is saved
                            on the customer profile and shown for future orders.
                        </p>
                    </div>
                    <group>
                        <field name="order_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                    </group>
                    <div class="row" style="margin:10px 0;">
                        <!-- LEFT: previous rating (read-only snapshot) -->
                        <div class="col-6">
                            <div class="alert alert-light" style="min-height:120px;">
                                <strong>Previous Rating</strong>
                                <hr style="margin:6px 0;"/>
                                <div invisible="is_new_customer">
                                    <field name="previous_rating_value" widget="badge"
                                           nolabel="1" readonly="1"
                                           decoration-success="previous_rating_value == 'perfect'"
                                           decoration-info="previous_rating_value == 'very_good'"
                                           decoration-primary="previous_rating_value == 'good'"
                                           decoration-warning="previous_rating_value == 'fair'"
                                           decoration-danger="previous_rating_value == 'poor'"
                                           decoration-muted="previous_rating_value == 'skipped'"/>
                                    <div style="margin-top:8px;">
                                        <strong style="font-size:11px;">Previous Notes:</strong>
                                        <div class="text-muted"
                                             style="font-size:12px; white-space:pre-wrap;">
                                            <field name="previous_rating_notes"
                                                   nolabel="1" readonly="1"/>
                                        </div>
                                    </div>
                                </div>
                                <div invisible="not is_new_customer"
                                     class="text-muted text-center"
                                     style="padding-top:20px; font-style:italic;">
                                    New Customer
                                </div>
                            </div>
                        </div>
                        <!-- RIGHT: currently-selected rating (live) -->
                        <div class="col-6">
                            <div class="alert alert-light text-center"
                                 style="min-height:120px;">
                                <strong>Selected Rating</strong>
                                <hr style="margin:6px 0;"/>
                                <field name="rating_value" widget="badge" nolabel="1"
                                       readonly="1"
                                       decoration-success="rating_value == 'perfect'"
                                       decoration-info="rating_value == 'very_good'"
                                       decoration-primary="rating_value == 'good'"
                                       decoration-warning="rating_value == 'fair'"
                                       decoration-danger="rating_value == 'poor'"/>
                                <div class="text-muted"
                                     style="font-size:11px; margin-top:8px;">
                                    Click a colored button below to choose, then
                                    press <strong>Save</strong> to confirm.
                                </div>
                            </div>
                        </div>
                    </div>
                    <separator string="Notes (optional)"/>
                    <group>
                        <field name="rating_notes" nolabel="1"
                               placeholder="Any notes about this customer's behavior..."/>
                    </group>
                    <separator string="Select a Rating"/>
                    <div class="text-center" style="padding:15px 0;">
                        <button name="action_select_perfect" type="object"
                                string="Perfect"
                                class="btn btn-success"
                                style="min-width:130px; margin:6px; font-weight:bold;"/>
                        <button name="action_select_very_good" type="object"
                                string="Very Good"
                                class="btn btn-info"
                                style="min-width:130px; margin:6px; font-weight:bold; color:white;"/>
                        <button name="action_select_good" type="object"
                                string="Good"
                                class="btn btn-primary"
                                style="min-width:130px; margin:6px; font-weight:bold;"/>
                        <button name="action_select_fair" type="object"
                                string="Fair"
                                class="btn btn-warning"
                                style="min-width:130px; margin:6px; font-weight:bold;"/>
                        <button name="action_select_poor" type="object"
                                string="Poor"
                                class="btn btn-danger"
                                style="min-width:130px; margin:6px; font-weight:bold;"/>
                    </div>
                    <div class="text-center text-muted" style="font-size:12px;">
                        <span style="color:#28a745;">●</span> Perfect &#160;
                        <span style="color:#17a2b8;">●</span> Very Good &#160;
                        <span style="color:#007bff;">●</span> Good &#160;
                        <span style="color:#ffc107;">●</span> Fair &#160;
                        <span style="color:#dc3545;">●</span> Poor
                    </div>
                </sheet>
                <footer>
                    <button name="action_save_rating" type="object"
                            string="Save" class="btn-primary"/>
                    <button name="action_skip_rating" type="object"
                            string="Skip" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
