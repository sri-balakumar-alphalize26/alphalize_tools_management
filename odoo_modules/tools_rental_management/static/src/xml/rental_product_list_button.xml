<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="tools_rental_management.RentalProductListView" t-inherit="web.ListView" t-inherit-mode="primary">
        <xpath expr="//Layout/t[@t-set-slot='control-panel-create-button']" position="inside">
            <button type="button" class="btn btn-primary btn-sm ms-1"
                    t-on-click="() => this.onGenerateSerials()">
                <i class="fa fa-cogs me-1"/>Generate Serialized Products
            </button>
            <button type="button" class="btn btn-danger btn-sm ms-1"
                    t-on-click="() => this.onDeleteSelected()">
                <i class="fa fa-trash me-1"/>Delete Selected
            </button>
        </xpath>
    </t>

</templates>
