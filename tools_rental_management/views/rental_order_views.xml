<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ RENTAL ORDER LIST ═══ -->
    <record id="view_rental_order_tree" model="ir.ui.view">
        <field name="name">rental.order.tree</field>
        <field name="model">rental.order</field>
        <field name="arch" type="xml">
            <list decoration-danger="is_late"
                  decoration-success="state == 'done'"
                  decoration-info="state == 'checked_out'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="customer_code" string="Customer ID" optional="show"/>
                <field name="partner_id" string="Customer"/>
                <field name="date_order" string="Date"/>
                <field name="rental_period_type" string="Period"/>
                <field name="total_amount" sum="Total" string="Amount"/>
                <field name="is_late" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'confirmed'"
                       decoration-warning="state == 'checked_out'"
                       decoration-success="state in ('done', 'invoiced')"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ═══ RENTAL ORDER FORM ═══ -->
    <record id="view_rental_order_form" model="ir.ui.view">
        <field name="name">rental.order.form</field>
        <field name="model">rental.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Workflow Buttons -->
                    <button name="action_confirm" type="object"
                            string="Confirm" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_checkout_wizard" type="object"
                            string="⬆ Check-Out Tools" class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_discount_wizard" type="object"
                            string="Discount" class="btn-warning"
                            invisible="state != 'checked_out'"/>
                    <button name="action_checkin_wizard" type="object"
                            string="⬇ Check-In Tools" class="btn-primary"
                            invisible="state != 'checked_out'"/>
                    <button name="action_print_checkout_invoice" type="object"
                            string="Print Checkout Invoice"
                            invisible="state not in ('checked_out', 'checked_in', 'invoiced')"/>
                    <button name="action_done" type="object"
                            string="Mark Done" class="btn-primary"
                            invisible="state != 'checked_in'"/>
                    <button name="action_print_checkin_invoice" type="object"
                            string="Print Check-In Invoice"
                            invisible="state != 'invoiced'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state in ('invoiced', 'cancelled')"
                            confirm="Are you sure you want to cancel this rental?"/>
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,checked_out,checked_in,invoiced"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <!-- Late Return Banner -->
                    <div class="alert alert-danger" role="alert"
                         invisible="not is_late"
                         style="margin-bottom: 10px;">
                        <strong>⚠ LATE RETURN</strong> — This rental has exceeded the planned return date!
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Customer">
                            <field name="customer_code" readonly="1"
                                   string="Customer ID"
                                   invisible="not customer_code"/>
                            <field name="partner_id"
                                   readonly="state != 'draft'"
                                   context="{'show_address': 1}"/>
                            <field name="partner_phone"/>
                            <field name="partner_email"/>
                            <field name="user_id"/>
                        </group>
                        <group string="Rental Period">
                            <field name="date_order" readonly="state != 'draft'"/>
                            <field name="rental_period_type"
                                   readonly="state not in ('draft', 'confirmed')"/>
                            <field name="rental_duration" string="Duration"
                                   readonly="state not in ('draft', 'confirmed')"/>
                            <field name="date_planned_checkout"/>
                            <field name="date_planned_checkin"/>
                        </group>
                    </group>
                    <group invisible="state in ('draft', 'confirmed')">
                        <group string="Check-Out / Check-In">
                            <field name="date_checkout" readonly="1"/>
                            <field name="date_checkin" readonly="1"/>
                            <field name="actual_duration_display" readonly="1" string="Duration"/>
                        </group>
                        <group string="Financials">
                            <field name="advance_amount" readonly="1"
                                   invisible="advance_amount == 0"/>
                            <field name="late_fee" readonly="1" string="Late Fees"
                                   invisible="late_fee == 0"/>
                            <field name="damage_charges" readonly="1"
                                   invisible="damage_charges == 0"/>
                            <field name="discount_amount"
                                   readonly="state in ('invoiced', 'cancelled')"
                                   invisible="discount_amount == 0"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                    </group>
                    <group invisible="state not in ('draft', 'confirmed')">
                        <group string="Financials">
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Rental Lines -->
                        <page string="Rental Lines" name="lines">
                            <field name="line_ids"
                                   readonly="state in ('done', 'invoiced', 'cancelled')">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" string="Tool (Serial No.)"
                                           required="1"
                                           domain="[('is_rental_tool', '=', True), ('rental_available', '=', True)]"
                                           context="{'rental_order_product_select': True}"/>
                                    <field name="tool_id" column_invisible="1" force_save="1"/>
                                    <field name="tool_category_id" column_invisible="1"
                                           force_save="1"/>
                                    <field name="pricing_id" string="Pricing Rule"
                                           force_save="1"
                                           domain="['|', ('tool_id', '=', tool_id), '&amp;', ('tool_id', '=', False), ('category_id', '=', tool_category_id)]"/>
                                    <field name="unit_price" string="Price" readonly="1"
                                           force_save="1"/>
                                    <field name="period_type" string="Per"/>
                                    <field name="planned_duration" string="Duration"/>
                                    <field name="tool_available_qty" column_invisible="1"/>
                                    <field name="quantity" column_invisible="1"/>
                                    <field name="returned_qty" column_invisible="1"/>
                                    <field name="pending_qty" column_invisible="1"/>
                                    <field name="qty_warning" column_invisible="1"/>
                                    <field name="total_cost" sum="Total" string="Total"/>
                                    <field name="checkout_condition" string="Out Condition"
                                           readonly="1" optional="show"/>
                                    <field name="checkin_condition" string="In Condition"
                                           readonly="1" optional="show"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <!-- Totals Summary -->
                            <group class="oe_subtotal_footer oe_right">
                                <field name="subtotal" string="Subtotal"/>
                                <field name="late_fee" string="Late Fees"
                                       invisible="late_fee == 0"/>
                                <field name="damage_charges" string="Damage Charges"
                                       invisible="damage_charges == 0"/>
                                <field name="discount_amount" string="Discount (-)"
                                       invisible="discount_amount == 0"/>
                                <field name="total_amount"
                                       class="oe_subtotal_footer_separator"
                                       string="Total"/>
                                <field name="advance_amount" string="Advance Paid (-)"
                                       invisible="advance_amount == 0 or advance_returned"/>
                                <field name="amount_due"
                                       class="oe_subtotal_footer_separator"
                                       string="Amount Due"
                                       invisible="advance_amount == 0 or advance_returned"/>
                            </group>
                        </page>

                        <!-- Timesheet / Activity Log -->
                        <page string="Timesheet / Log" name="timesheet">
                            <field name="timesheet_ids" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="action" widget="badge"/>
                                    <field name="user_id"/>
                                    <field name="notes"/>
                                    <field name="cost_impact" optional="show"/>
                                </list>
                            </field>
                        </page>

                        <!-- Check-Out Details -->
                        <page string="Check-Out Details" name="checkout_details"
                              invisible="state in ('draft', 'confirmed')">
                            <group col="2">
                                <group string="Check-Out Summary">
                                    <field name="customer_code" readonly="1"
                                           string="Customer ID"/>
                                    <field name="date_checkout" readonly="1"
                                           string="Check-Out Date"/>
                                    <field name="checkout_signature_date_display" readonly="1"
                                           string="Signed On"/>
                                    <field name="user_id" readonly="1"
                                           string="Checked Out By"/>
                                </group>
                                <group string="Rental Info">
                                    <field name="rental_period_type" readonly="1"
                                           string="Billing Period"/>
                                    <field name="rental_duration" readonly="1"
                                           string="Planned Duration"/>
                                    <field name="date_planned_checkin" readonly="1"
                                           string="Planned Return"/>
                                    <field name="advance_amount" readonly="1"
                                           string="Advance Collected"
                                           invisible="advance_amount == 0"/>
                                </group>
                            </group>
                            <separator string="Tool Conditions at Check-Out"/>
                            <field name="line_ids" readonly="1">
                                <list create="false" delete="false" no_open="1">
                                    <field name="tool_display_name" string="Tool" readonly="1"/>
                                    <field name="serial_number" string="Serial No."/>
                                    <field name="unit_price" string="Price"/>
                                    <field name="planned_duration" string="Duration"/>
                                    <field name="rental_cost" string="Rental Cost"/>
                                    <field name="checkout_condition" string="Condition"
                                           widget="badge"
                                           decoration-success="checkout_condition in ('excellent', 'good')"
                                           decoration-warning="checkout_condition == 'fair'"
                                           decoration-danger="checkout_condition in ('poor', 'damaged')"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>

                            <separator string="Signatures &amp; Photos"/>
                            <field name="checkout_media_ids">
                                <list create="false" delete="false">
                                    <field name="label" string="Type" readonly="1"/>
                                    <field name="signer_name" string="Name" readonly="1"/>
                                    <field name="captured_on_display" string="Date &amp; Time" readonly="1"/>
                                    <field name="media_kind" string="Kind" widget="badge"
                                           decoration-info="media_kind == 'signature'"
                                           decoration-success="media_kind == 'photo'"/>
                                    <field name="image_data" string="Preview"
                                           widget="image" options='{"size": [80, 60]}'/>
                                </list>
                                <form string="Check-Out — Signature / Photo">
                                    <group>
                                        <group string="Details">
                                            <field name="label" string="Type" readonly="1"/>
                                            <field name="media_kind" string="Kind" readonly="1"/>
                                            <field name="signer_name" string="Name / Signer" readonly="1"/>
                                            <field name="captured_on_display" string="Date &amp; Time" readonly="1"/>
                                        </group>
                                    </group>
                                    <separator string="Full Size View"/>
                                    <field name="image_data" widget="image"
                                           nolabel="1" readonly="1"
                                           options='{"size": [500, 400]}'/>
                                    <footer>
                                        <button string="Close" class="btn-primary" special="cancel"/>
                                    </footer>
                                </form>
                            </field>
                        </page>

                        <!-- Check-In Details -->
                        <page string="Check-In Details" name="checkin_details"
                              invisible="state in ('draft', 'confirmed', 'checked_out')">
                            <group col="2">
                                <group string="Check-In Summary">
                                    <field name="customer_code" readonly="1"
                                           string="Customer ID"/>
                                    <field name="date_checkin" readonly="1"
                                           string="Check-In Date"/>
                                    <field name="actual_duration_display" readonly="1"
                                           string="Actual Duration"/>
                                    <field name="user_id" readonly="1"
                                           string="Checked In By"/>
                                </group>
                                <group string="Financials">
                                    <field name="advance_amount" readonly="1"
                                           invisible="advance_amount == 0"
                                           string="Advance Collected"/>
                                    <field name="advance_returned" readonly="1"
                                           invisible="advance_amount == 0"
                                           string="Advance Returned"/>
                                    <field name="late_fee" readonly="1"
                                           string="Total Late Fees"
                                           invisible="late_fee == 0"/>
                                    <field name="damage_charges" readonly="1"
                                           invisible="damage_charges == 0"
                                           string="Damage Charges"/>
                                </group>
                            </group>
                            <separator string="Tool Conditions at Check-In"/>
                            <field name="line_ids" readonly="1">
                                <list create="false" delete="false" no_open="1">
                                    <field name="tool_display_name" string="Tool" readonly="1"/>
                                    <field name="serial_number" string="Serial No."/>
                                    <field name="checkout_condition" string="Out Condition"
                                           widget="badge"
                                           decoration-success="checkout_condition in ('excellent', 'good')"
                                           decoration-warning="checkout_condition == 'fair'"
                                           decoration-danger="checkout_condition in ('poor', 'damaged')"/>
                                    <field name="checkin_condition" string="In Condition"
                                           widget="badge"
                                           decoration-success="checkin_condition in ('excellent', 'good')"
                                           decoration-warning="checkin_condition == 'fair'"
                                           decoration-danger="checkin_condition in ('poor', 'damaged')"/>
                                    <field name="extra_days" string="Extra Days"
                                           decoration-danger="extra_days > 0"
                                           optional="show"/>
                                    <field name="damage_note" string="Damage Notes"/>
                                    <field name="late_fee_amount" string="Late Fee"
                                           decoration-danger="late_fee_amount > 0"/>
                                    <field name="damage_charge" string="Damage Charge"
                                           decoration-danger="damage_charge > 0"/>
                                    <field name="discount_line_amount" string="Discount"
                                           decoration-success="discount_line_amount > 0"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="late_fee" string="Total Late Fees"
                                       invisible="late_fee == 0"/>
                                <field name="damage_charges" string="Total Damage Charges"
                                       invisible="damage_charges == 0"/>
                                <field name="discount_amount" string="Total Discount"
                                       invisible="discount_amount == 0"/>
                                <field name="total_amount"
                                       class="oe_subtotal_footer_separator"
                                       string="Total"/>
                                <field name="advance_amount" string="Advance Paid (-)"
                                       invisible="advance_amount == 0 or advance_returned"/>
                                <field name="amount_due"
                                       class="oe_subtotal_footer_separator"
                                       string="Amount Due"
                                       invisible="advance_amount == 0 or advance_returned"/>
                            </group>

                            <separator string="Signatures"/>
                            <field name="checkin_media_ids">
                                <list create="false" delete="false">
                                    <field name="label" string="Type" readonly="1"/>
                                    <field name="signer_name" string="Signer Name" readonly="1"/>
                                    <field name="captured_on_display" string="Signed On" readonly="1"/>
                                    <field name="media_kind" string="Kind" widget="badge"
                                           decoration-info="media_kind == 'signature'"
                                           decoration-success="media_kind == 'photo'"/>
                                    <field name="image_data" string="Preview"
                                           widget="image" options='{"size": [80, 60]}'/>
                                </list>
                                <form string="Check-In — Signature">
                                    <group>
                                        <group string="Details">
                                            <field name="label" string="Type" readonly="1"/>
                                            <field name="media_kind" string="Kind" readonly="1"/>
                                            <field name="signer_name" string="Signer Name" readonly="1"/>
                                            <field name="captured_on_display" string="Signed On" readonly="1"/>
                                        </group>
                                    </group>
                                    <separator string="Full Size View"/>
                                    <field name="image_data" widget="image"
                                           nolabel="1" readonly="1"
                                           options='{"size": [500, 400]}'/>
                                    <footer>
                                        <button string="Close" class="btn-primary" special="cancel"/>
                                    </footer>
                                </form>
                            </field>
                        </page>

                        <!-- Discount Details -->
                        <page string="Discount Details" name="discount_details"
                              invisible="discount_amount == 0">
                            <group col="2">
                                <group string="Authorization Info">
                                    <field name="discount_authorized_by"
                                           string="Authorized By"
                                           readonly="state in ('done', 'invoiced', 'cancelled')"/>
                                    <field name="discount_applied_date_display" readonly="1"
                                           string="Applied On"/>
                                </group>
                                <group string="Discount Summary">
                                    <field name="discount_amount" readonly="1"
                                           string="Total Discount"/>
                                </group>
                            </group>

                            <separator string="Authorizer Photos &amp; Signature"/>
                            <field name="discount_media_ids">
                                <list create="false" delete="false">
                                    <field name="label" string="Type" readonly="1"/>
                                    <field name="signer_name" string="Authorized By" readonly="1"/>
                                    <field name="captured_on_display" string="Date &amp; Time" readonly="1"/>
                                    <field name="media_kind" string="Kind" widget="badge"
                                           decoration-success="media_kind == 'photo'"
                                           decoration-info="media_kind == 'signature'"/>
                                    <field name="image_data" string="Preview"
                                           widget="image" options='{"size": [80, 60]}'/>
                                </list>
                                <form string="Discount — Photo / Signature">
                                    <group>
                                        <group string="Details">
                                            <field name="label" string="Type" readonly="1"/>
                                            <field name="media_kind" string="Kind" readonly="1"/>
                                            <field name="signer_name" string="Authorized By" readonly="1"/>
                                            <field name="captured_on_display" string="Date &amp; Time" readonly="1"/>
                                        </group>
                                    </group>
                                    <separator string="Full Size View"/>
                                    <field name="image_data" widget="image"
                                           nolabel="1" readonly="1"
                                           options='{"size": [500, 400]}'/>
                                    <footer>
                                        <button string="Close" class="btn-primary" special="cancel"/>
                                    </footer>
                                </form>
                            </field>

                            <separator string="Discount Breakdown"/>
                            <field name="line_ids" readonly="1">
                                <list create="false" delete="false" no_open="1">
                                    <field name="tool_display_name" string="Tool" readonly="1"/>
                                    <field name="serial_number" string="Serial No."/>
                                    <field name="rental_cost" string="Rental Cost"/>
                                    <field name="late_fee_amount" string="Late Fee"
                                           decoration-danger="late_fee_amount > 0"/>
                                    <field name="damage_charge" string="Damage Charge"
                                           decoration-danger="damage_charge > 0"/>
                                    <field name="discount_type" string="Disc. Type"/>
                                    <field name="discount_value" string="Disc. Value"/>
                                    <field name="discount_line_amount" string="Discount Amount"
                                           decoration-success="discount_line_amount > 0"/>
                                    <field name="total_cost" string="Final Amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="discount_amount" readonly="1"
                                       string="Total Discount"
                                       widget="monetary"/>
                            </group>
                        </page>

                        <!-- Tool Photos -->
                        <page string="Tool Photos" name="tool_photos"
                              invisible="state in ('draft', 'confirmed')">
                            <group col="2">
                                <group string="Check-Out Info">
                                    <field name="date_checkout" readonly="1"
                                           string="Check-Out Date"/>
                                    <field name="checkout_signature_date_display" readonly="1"
                                           string="Checked Out At"/>
                                </group>
                                <group/>
                            </group>
                            <separator string="Tool Photos at Check-Out"/>
                            <field name="line_ids"
                                   readonly="state in ('invoiced', 'cancelled')">
                                <list create="false" delete="false" editable="bottom">
                                    <field name="tool_display_name" string="Tool" readonly="1"/>
                                    <field name="serial_number" string="Serial No." readonly="1"/>
                                    <field name="checkout_condition" string="Condition"
                                           widget="selection"
                                           decoration-success="checkout_condition in ('excellent', 'good')"
                                           decoration-warning="checkout_condition == 'fair'"
                                           decoration-danger="checkout_condition in ('poor', 'damaged')"/>
                                    <field name="checkout_tool_image" string="Out Photo"
                                           widget="image"
                                           options='{"size": [80, 60], "zoom": true}'/>
                                    <field name="checkin_tool_image" string="In Photo"
                                           widget="image"
                                           options='{"size": [80, 60], "zoom": true}'/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                                <form string="Tool Photo Preview">
                                    <group>
                                        <group>
                                            <field name="tool_display_name" string="Tool" readonly="1"/>
                                            <field name="serial_number" string="Serial No." readonly="1"/>
                                            <field name="checkout_condition" string="Condition"
                                                   widget="selection"
                                                   decoration-success="checkout_condition in ('excellent', 'good')"
                                                   decoration-warning="checkout_condition == 'fair'"
                                                   decoration-danger="checkout_condition in ('poor', 'damaged')"/>
                                            <field name="checkin_condition" string="Check-In Condition"
                                                   widget="selection"
                                                   decoration-success="checkin_condition in ('excellent', 'good')"
                                                   decoration-warning="checkin_condition == 'fair'"
                                                   decoration-danger="checkin_condition in ('poor', 'damaged')"/>
                                        </group>
                                    </group>
                                    <separator string="Check-Out Photo"/>
                                    <field name="checkout_tool_image" widget="image"
                                           nolabel="1"
                                           options='{"size": [500, 400], "zoom": true}'/>
                                    <separator string="Check-In Photo"/>
                                    <field name="checkin_tool_image" widget="image"
                                           nolabel="1"
                                           options='{"size": [500, 400], "zoom": true}'/>
                                    <footer>
                                        <button string="Save &amp; Close" class="btn-primary" special="save"/>
                                        <button string="Close" special="cancel"/>
                                    </footer>
                                </form>
                            </field>
                        </page>

                        <!-- Notes & Terms -->
                        <page string="Notes &amp; Terms" name="notes">
                            <group>
                                <field name="notes" placeholder="Internal notes..."/>
                            </group>
                            <group>
                                <field name="terms" placeholder="Terms and conditions..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ SEARCH VIEW ═══ -->
    <record id="view_rental_order_search" model="ir.ui.view">
        <field name="name">rental.order.search</field>
        <field name="model">rental.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Search"
                       filter_domain="['|', '|', '|',
                           ('name', 'ilike', self),
                           ('partner_id', 'ilike', self),
                           ('line_ids.product_id', 'ilike', self),
                           ('user_id', 'ilike', self)]"/>
                <field name="partner_id"/>
                <field name="line_ids" string="Product"
                       filter_domain="[('line_ids.product_id', 'ilike', self)]"/>
                <field name="user_id"/>
                <separator/>
                <filter name="draft" string="Draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="confirmed" string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="checked_out" string="Checked Out"
                        domain="[('state', '=', 'checked_out')]"/>
                <filter name="checked_in" string="Checked In"
                        domain="[('state', '=', 'checked_in')]"/>
                <filter name="done" string="Done"
                        domain="[('state', '=', 'done')]"/>
                <filter name="invoiced" string="Invoiced"
                        domain="[('state', '=', 'invoiced')]"/>
                <separator/>
                <filter name="late" string="Late Returns"
                        domain="[('is_late', '=', True)]"/>
                <filter name="today_checkout" string="Check-Out Today"
                        domain="[('date_planned_checkout', '&gt;=', (context_today()).strftime('%Y-%m-%d')),
                                 ('date_planned_checkout', '&lt;', (context_today() + datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="today_checkin" string="Return Due Today"
                        domain="[('date_planned_checkin', '&gt;=', (context_today()).strftime('%Y-%m-%d')),
                                 ('date_planned_checkin', '&lt;', (context_today() + datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group>
                    <filter name="group_state" string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_customer" string="Customer"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_period" string="Billing Period"
                            context="{'group_by': 'rental_period_type'}"/>
                    <filter name="group_user" string="Responsible"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_month" string="Order Month"
                            context="{'group_by': 'date_order:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ CALENDAR VIEW ═══ -->
    <record id="view_rental_order_calendar" model="ir.ui.view">
        <field name="name">rental.order.calendar</field>
        <field name="model">rental.order</field>
        <field name="arch" type="xml">
            <calendar string="Rentals" date_start="date_planned_checkout"
                      date_stop="date_planned_checkin" color="state"
                      mode="month">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="total_amount"/>
            </calendar>
        </field>
    </record>

    <!-- ═══ PIVOT VIEW ═══ -->
    <record id="view_rental_order_pivot" model="ir.ui.view">
        <field name="name">rental.order.pivot</field>
        <field name="model">rental.order</field>
        <field name="arch" type="xml">
            <pivot string="Rental Analysis">
                <field name="date_order" type="row" interval="month"/>
                <field name="rental_period_type" type="col"/>
                <field name="total_amount" type="measure"/>
                <field name="late_fee" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ═══ GRAPH VIEW ═══ -->
    <record id="view_rental_order_graph" model="ir.ui.view">
        <field name="name">rental.order.graph</field>
        <field name="model">rental.order</field>
        <field name="arch" type="xml">
            <graph string="Rental Revenue" type="bar">
                <field name="date_order" type="row" interval="month"/>
                <field name="total_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ═══ ACTION ═══ -->
    <record id="action_rental_order" model="ir.actions.act_window">
        <field name="name">Rental Orders</field>
        <field name="res_model">rental.order</field>
        <field name="view_mode">list,form,calendar,pivot,graph</field>
        <field name="search_view_id" ref="view_rental_order_search"/>
        <field name="context">{'search_default_checked_out': 1}</field>
    </record>

    <record id="action_rental_order_all" model="ir.actions.act_window">
        <field name="name">All Rental Orders</field>
        <field name="res_model">rental.order</field>
        <field name="view_mode">list,form,calendar,pivot,graph</field>
        <field name="search_view_id" ref="view_rental_order_search"/>
    </record>

    <!-- ═══ TIMESHEET ACTION ═══ -->
    <record id="action_rental_timesheet" model="ir.actions.act_window">
        <field name="name">Rental Timesheet</field>
        <field name="res_model">rental.timesheet</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
