<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ PAPER FORMATS ═══ -->
    <record id="paperformat_rental_a4" model="report.paperformat">
        <field name="name">Rental Invoice A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">40</field>
        <field name="margin_bottom">28</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">35</field>
        <field name="dpi">90</field>
    </record>

    <record id="paperformat_rental_a5" model="report.paperformat">
        <field name="name">Rental Invoice A5</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_width">148</field>
        <field name="page_height">210</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">30</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">25</field>
        <field name="dpi">90</field>
    </record>

    <!-- ═══ CHECKOUT INVOICE REPORTS ═══ -->
    <record id="action_report_checkout_invoice_a4" model="ir.actions.report">
        <field name="name">Checkout Invoice (A4)</field>
        <field name="model">rental.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tools_rental_management.report_checkout_invoice</field>
        <field name="report_file">tools_rental_management.report_checkout_invoice</field>
        <field name="print_report_name">'Checkout_Invoice_%s' % object.name</field>
        <field name="paperformat_id" ref="paperformat_rental_a4"/>
    </record>

    <record id="action_report_checkout_invoice_a5" model="ir.actions.report">
        <field name="name">Checkout Invoice (A5)</field>
        <field name="model">rental.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tools_rental_management.report_checkout_invoice</field>
        <field name="report_file">tools_rental_management.report_checkout_invoice</field>
        <field name="print_report_name">'Checkout_Invoice_%s' % object.name</field>
        <field name="paperformat_id" ref="paperformat_rental_a5"/>
    </record>

    <!-- ═══ CHECK-IN INVOICE REPORTS ═══ -->
    <record id="action_report_checkin_invoice_a4" model="ir.actions.report">
        <field name="name">Check-In Invoice (A4)</field>
        <field name="model">rental.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tools_rental_management.report_checkin_invoice</field>
        <field name="report_file">tools_rental_management.report_checkin_invoice</field>
        <field name="print_report_name">'CheckIn_Invoice_%s' % object.name</field>
        <field name="paperformat_id" ref="paperformat_rental_a4"/>
    </record>

    <record id="action_report_checkin_invoice_a5" model="ir.actions.report">
        <field name="name">Check-In Invoice (A5)</field>
        <field name="model">rental.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tools_rental_management.report_checkin_invoice</field>
        <field name="report_file">tools_rental_management.report_checkin_invoice</field>
        <field name="print_report_name">'CheckIn_Invoice_%s' % object.name</field>
        <field name="paperformat_id" ref="paperformat_rental_a5"/>
    </record>
</odoo>
