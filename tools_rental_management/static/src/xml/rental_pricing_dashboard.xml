<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="tools_rental_management.RentalPricingDashboard">
        <div class="rtr_dashboard o_action">

            <!-- ── Header ────────────────────────────────── -->
            <div class="rtr_header">
                <h2><i class="fa fa-money me-2"/>Pricing Rules</h2>
            </div>

            <!-- ── Scrollable content area ───────────────── -->
            <div class="rtr_scroll_area">

                <!-- ── Summary Cards ─────────────────────── -->
                <div class="rtr_cards">
                    <div class="rtr_card rtr_card_purple">
                        <div class="rtr_card_value" t-esc="state.totalProducts"/>
                        <div class="rtr_card_label">Products</div>
                    </div>
                    <div class="rtr_card rtr_card_blue">
                        <div class="rtr_card_value" t-esc="state.totalUnits"/>
                        <div class="rtr_card_label">Total Units</div>
                    </div>
                    <div class="rtr_card rtr_card_green">
                        <div class="rtr_card_value" t-esc="formatMoney(state.avgPrice)"/>
                        <div class="rtr_card_label">Avg Price / Day</div>
                    </div>
                    <div class="rtr_card rtr_card_orange">
                        <div class="rtr_card_value" t-esc="state.totalWithLateFee"/>
                        <div class="rtr_card_label">With Late Fee</div>
                    </div>
                </div>

                <!-- ── Filter Bar ────────────────────────── -->
                <div class="rtr_filter_bar">
                    <div class="rtr_filter_item">
                        <i class="fa fa-search rtr_search_icon"/>
                        <input type="text" class="rtr_search_input"
                               placeholder="Search products..."
                               t-on-input="onSearchInput"
                               t-att-value="state.searchQuery"/>
                    </div>
                    <div class="rtr_filter_item">
                        <label>Category:</label>
                        <select class="rtr_select" t-on-change="onFilterCategory">
                            <option value="all">All Categories</option>
                            <t t-foreach="state.categories" t-as="cat" t-key="cat.id">
                                <option t-att-value="cat.id" t-esc="cat.name"/>
                            </t>
                        </select>
                    </div>
                    <div class="rtr_filter_item">
                        <label>Period:</label>
                        <select class="rtr_select" t-on-change="onFilterPeriod">
                            <option value="all">All Periods</option>
                            <option value="day">Per Day</option>
                            <option value="week">Per Week</option>
                            <option value="month">Per Month</option>
                            <option value="fixed">Fixed Price</option>
                        </select>
                    </div>
                    <div class="rtr_filter_count">
                        Showing <strong t-esc="state.records.length"/> products
                    </div>
                </div>

                <!-- ── Data Table ────────────────────────── -->
                <div class="rtr_table_wrap">
                    <table class="rtr_table">
                        <thead>
                            <tr>
                                <th class="rtr_th_num">#</th>
                                <th class="rtr_th_sortable rtr_th_name"
                                    t-on-click="() => this.onSort('product_name')">
                                    Product
                                    <i t-attf-class="fa {{ getSortIcon('product_name') }} rtr_sort_icon"/>
                                </th>
                                <th class="rtr_th_sortable"
                                    t-on-click="() => this.onSort('category_id')">
                                    Category
                                    <i t-attf-class="fa {{ getSortIcon('category_id') }} rtr_sort_icon"/>
                                </th>
                                <th class="rtr_th_sortable rtr_th_center"
                                    t-on-click="() => this.onSort('serial_count')">
                                    Units
                                    <i t-attf-class="fa {{ getSortIcon('serial_count') }} rtr_sort_icon"/>
                                </th>
                                <th class="rtr_th_sortable rtr_th_center"
                                    t-on-click="() => this.onSort('period_type')">
                                    Period
                                    <i t-attf-class="fa {{ getSortIcon('period_type') }} rtr_sort_icon"/>
                                </th>
                                <th class="rtr_th_sortable rtr_th_right"
                                    t-on-click="() => this.onSort('price')">
                                    Price
                                    <i t-attf-class="fa {{ getSortIcon('price') }} rtr_sort_icon"/>
                                </th>
                                <th class="rtr_th_sortable rtr_th_right"
                                    t-on-click="() => this.onSort('late_fee_per_day')">
                                    Late Fee / Day
                                    <i t-attf-class="fa {{ getSortIcon('late_fee_per_day') }} rtr_sort_icon"/>
                                </th>
                                <th class="rtr_th_right">Min Dur.</th>
                                <th class="rtr_th_right">Max Dur.</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.records" t-as="rec" t-key="rec.id">
                                <tr style="cursor:pointer" t-on-click="() => this.onOpenPricing(rec)">
                                    <td class="rtr_td_num">
                                        <t t-esc="rec_index + 1"/>
                                    </td>
                                    <td class="rtr_td_name">
                                        <t t-esc="rec.product_name"/>
                                    </td>
                                    <td>
                                        <t t-esc="rec.category_id ? rec.category_id[1] : '-'"/>
                                    </td>
                                    <td class="rtr_td_center">
                                        <span t-attf-class="rtr_badge {{ rec.serial_count > 1 ? 'rtr_badge_info' : 'rtr_badge_muted' }}">
                                            <t t-esc="rec.serial_count"/>
                                        </span>
                                    </td>
                                    <td class="rtr_td_center">
                                        <span t-attf-class="rtr_badge {{ getPeriodClass(rec.period_type) }}">
                                            <t t-esc="getPeriodLabel(rec.period_type)"/>
                                        </span>
                                    </td>
                                    <td t-attf-class="rtr_td_right {{ rec.price > 0 ? 'rtr_text_green' : 'rtr_text_red' }}">
                                        <strong t-esc="formatMoney(rec.price)"/>
                                    </td>
                                    <td class="rtr_td_right">
                                        <t t-if="rec.late_fee_per_day > 0">
                                            <span class="rtr_text_red">
                                                <t t-esc="formatMoney(rec.late_fee_per_day)"/>
                                            </span>
                                        </t>
                                        <t t-else="">
                                            <span style="color:#ccc">-</span>
                                        </t>
                                    </td>
                                    <td class="rtr_td_right">
                                        <t t-esc="rec.min_duration || '-'"/>
                                    </td>
                                    <td class="rtr_td_right">
                                        <t t-esc="rec.max_duration || '-'"/>
                                    </td>
                                </tr>
                            </t>
                            <t t-if="!state.records.length">
                                <tr>
                                    <td colspan="10" class="rtr_no_data">
                                        No pricing rules match your filters
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </t>
</templates>
