<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ Multi-Company Record Rules ═══ -->
    <!-- Each branch/company sees ONLY its own records (strict isolation) -->

    <!-- Rental Tool: strict company isolation -->
    <record id="rental_tool_company_rule" model="ir.rule">
        <field name="name">Rental Tool: Multi-Company</field>
        <field name="model_id" ref="model_rental_tool"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', '=', company_id)]</field>
    </record>

    <!-- Rental Order: strict company isolation -->
    <record id="rental_order_company_rule" model="ir.rule">
        <field name="name">Rental Order: Multi-Company</field>
        <field name="model_id" ref="model_rental_order"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', '=', company_id)]</field>
    </record>

    <!-- Rental Order Line: strict company isolation via parent order -->
    <record id="rental_order_line_company_rule" model="ir.rule">
        <field name="name">Rental Order Line: Multi-Company</field>
        <field name="model_id" ref="model_rental_order_line"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', '=', company_id)]</field>
    </record>

    <!-- Rental Pricing: strict company isolation -->
    <record id="rental_pricing_company_rule" model="ir.rule">
        <field name="name">Rental Pricing: Multi-Company</field>
        <field name="model_id" ref="model_rental_pricing"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', '=', company_id)]</field>
    </record>

    <!-- Product: company isolation -->
    <record id="rental_product_company_rule" model="ir.rule">
        <field name="name">Product: Multi-Company (Rental)</field>
        <field name="model_id" ref="product.model_product_product"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', '=', company_id)]</field>
    </record>

    <!-- Tool Availability Report: company isolation -->
    <record id="rental_tool_report_company_rule" model="ir.rule">
        <field name="name">Tool Report: Multi-Company</field>
        <field name="model_id" ref="model_rental_tool_report"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', '=', company_id)]</field>
    </record>

    <!-- Rental Timesheet: company isolation via parent order -->
    <record id="rental_timesheet_company_rule" model="ir.rule">
        <field name="name">Rental Timesheet: Multi-Company</field>
        <field name="model_id" ref="model_rental_timesheet"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', '=', company_id)]</field>
    </record>


</odoo>
